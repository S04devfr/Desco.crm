<%- include('../layouts/header', {
  title: "Qo'shimcha Bo'lim — DESCO CRM",
  activePage: 'extra-' + subPage,
  user: user}) %>

<style>
/* spreadsheet styles */
.spreadsheet-input {
  border: 1px solid transparent;
  background: transparent;
  width: 100%;
  padding: 6px 10px;
  font-size: 13px;
  color: var(--text-primary);
  border-radius: 4px;
  transition: all 0.15s;
}
.spreadsheet-input:hover {
  background: var(--bg-primary);
  border-color: var(--border);
}
.spreadsheet-input:focus {
  background: var(--bg-secondary);
  border-color: var(--accent);
  outline: none;
  box-shadow: 0 0 0 2px var(--accent-soft);
}
.spreadsheet-input.success {
  border-color: var(--success) !important;
  background-color: var(--success-bg) !important;
}
.deals-tbl td {
  padding: 4px 6px !important; /* tighter padding for spreadsheet style */
}
</style>

<div class="page-header">
  <div>
    <h1 id="extraTitle">Qo'shimcha</h1>
    <p>Ma'lumotlar jadvalini to'g'ridan-to'g'ri tahrirlashingiz mumkin</p>
  </div>
  <div class="page-header-actions" style="display:flex; gap:8px;">
    <button class="btn btn-secondary btn-sm" onclick="loadExtraList()">
      <i class="fas fa-sync-alt"></i> Yangilash
    </button>
    <button class="btn btn-primary btn-sm" onclick="addExtraRow()">
      <i class="fas fa-plus"></i> Yangi qator qo'shish
    </button>
  </div>
</div>

<div class="card">
  <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
    <h3 id="tableHeader">Jadval</h3>
    <span id="rowCount" class="badge badge-purple">0</span>
  </div>
  <div class="table-wrap">
    <table class="deals-tbl" style="width:100%">
      <thead>
        <tr style="background:var(--bg-tertiary);">
          <th style="padding:10px 12px; font-size:11px; width:70px;">ID</th>
          <th style="padding:10px 12px; font-size:11px;">Ismi</th>
          <th style="padding:10px 12px; font-size:11px;">Raqami</th>
          <th style="padding:10px 12px; font-size:11px;">Viloyati</th>
          <th style="padding:10px 12px; font-size:11px; width:150px;">Narxi</th>
          <th style="padding:10px 12px; font-size:11px; width:150px;">Yo'lkira</th>
          <th style="padding:10px 12px; font-size:11px;">Izoh</th>
          <th style="padding:10px 12px; font-size:11px; width:80px; text-align:center;">Amallar</th>
        </tr>
      </thead>
      <tbody id="extraTableBody">
        <tr>
          <td colspan="8" style="text-align:center; padding:40px;">
            <div class="spinner" style="margin:auto"></div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<script>
const activeType = '<%= subPage %>'; // 'drivers' or 'branches'
const apiEndpoint = '/api/extra/' + activeType;

const titlesMap = {
  'drivers': 'Shopirlar',
  'branches': 'Ishonch Filiallari'
};

document.getElementById('extraTitle').textContent = titlesMap[activeType] || 'Qo\'shimcha';
document.getElementById('tableHeader').textContent = (titlesMap[activeType] || 'Ro\'yxat') + ' jadvali';

async function loadExtraList() {
  try {
    const tbody = document.getElementById('extraTableBody');
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center; padding:40px;"><div class="spinner" style="margin:auto"></div></td></tr>';

    const r = await fetch(apiEndpoint);
    const list = await r.json();
    
    if (!r.ok) throw new Error(list.message || 'Xatolik');

    document.getElementById('rowCount').textContent = list.length;

    if (!list.length) {
      tbody.innerHTML = '<tr><td colspan="8" style="text-align:center; padding:40px; color:var(--text-tertiary)"><i class="fas fa-list" style="font-size:28px; display:block; margin-bottom:8px;"></i>Jadvalda ma\'lumot yo\'q. "Yangi qator qo\'shish" tugmasini bosing.</td></tr>';
      return;
    }

    tbody.innerHTML = list.map(item => `
      <tr id="row-${item.id}">
        <td style="padding:10px 12px !important; color:var(--text-tertiary); font-size:12.5px;">#${item.id}</td>
        <td>
          <input type="text" class="spreadsheet-input" value="${escHtml(item.name)}" 
                 onchange="updateExtraField(${item.id}, 'name', this.value, this)" 
                 onkeydown="if(event.key==='Enter') this.blur()">
        </td>
        <td>
          <input type="text" class="spreadsheet-input" value="${escHtml(item.phone || '')}" 
                 onchange="updateExtraField(${item.id}, 'phone', this.value, this)" 
                 onkeydown="if(event.key==='Enter') this.blur()" placeholder="Telefon...">
        </td>
        <td>
          <input type="text" class="spreadsheet-input" value="${escHtml(item.region || '')}" 
                 onchange="updateExtraField(${item.id}, 'region', this.value, this)" 
                 onkeydown="if(event.key==='Enter') this.blur()" placeholder="Viloyat...">
        </td>
        <td>
          <input type="number" class="spreadsheet-input" value="${item.price || 0}" 
                 onchange="updateExtraField(${item.id}, 'price', this.value, this)" 
                 onkeydown="if(event.key==='Enter') this.blur()">
        </td>
        <td>
          <input type="number" class="spreadsheet-input" value="${item.travelCost || 0}" 
                 onchange="updateExtraField(${item.id}, 'travelCost', this.value, this)" 
                 onkeydown="if(event.key==='Enter') this.blur()">
        </td>
        <td>
          <input type="text" class="spreadsheet-input" value="${escHtml(item.notes || '')}" 
                 onchange="updateExtraField(${item.id}, 'notes', this.value, this)" 
                 onkeydown="if(event.key==='Enter') this.blur()" placeholder="Izoh...">
        </td>
        <td style="text-align:center;">
          <button class="btn btn-ghost btn-icon btn-sm text-danger" onclick="deleteExtraRow(${item.id})" style="padding:4px 8px;" title="Qatorni o\'chirish">
            <i class="fas fa-trash"></i>
          </button>
        </td>
      </tr>
    `).join('');
  } catch(e) {
    document.getElementById('extraTableBody').innerHTML = '<tr><td colspan="8" style="text-align:center; padding:40px; color:var(--danger)"><i class="fas fa-exclamation-triangle" style="font-size:28px; display:block; margin-bottom:8px;"></i>Yuklashda xato: ' + escHtml(e.message) + '</td></tr>';
  }
}

async function addExtraRow() {
  try {
    const r = await fetch(apiEndpoint, { method: 'POST' });
    const res = await r.json();
    if (!r.ok) throw new Error(res.message);
    
    if (typeof showToast === 'function') showToast('Qator qo\'shildi', 'success');
    await loadExtraList();
    
    // Focus the first input of the new row
    setTimeout(() => {
      const input = document.querySelector(`#row-${res.id} input`);
      if (input) {
        input.focus();
        input.select();
      }
    }, 100);
  } catch(e) {
    if (typeof showToast === 'function') showToast('Qator qo\'shishda xato', 'error');
  }
}

async function updateExtraField(id, field, value, inputEl) {
  try {
    inputEl.disabled = true;
    const body = {};
    body[field] = value;

    const r = await fetch(apiEndpoint + '/' + id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const res = await r.json();
    if (!r.ok) throw new Error(res.message);

    // Save visual feedback animation
    inputEl.classList.add('success');
    setTimeout(() => inputEl.classList.remove('success'), 1000);
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xato: ' + e.message, 'error');
  } finally {
    inputEl.disabled = false;
  }
}

async function deleteExtraRow(id) {
  if (!confirm('Qatorni o\'chirishni tasdiqlaysizmi?')) return;
  try {
    const r = await fetch(apiEndpoint + '/' + id, { method: 'DELETE' });
    if (!r.ok) throw new Error();
    
    if (typeof showToast === 'function') showToast('O\'chirildi', 'success');
    loadExtraList();
  } catch(e) {
    if (typeof showToast === 'function') showToast('O\'chirishda xato', 'error');
  }
}

function escHtml(s) {
  if (s == null) return '';
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

document.addEventListener('DOMContentLoaded', loadExtraList);
</script>
<%- include('../layouts/footer') %>
