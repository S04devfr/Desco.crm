<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'DESCO CRM' %></title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/custom.css">
    
    <style>
        .sidebar-active {
            @apply bg-blue-600 text-white;
        }
        .btn-primary {
            @apply px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition;
        }
        .btn-secondary {
            @apply px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition;
        }
        .badge-success {
            @apply inline-block px-3 py-1 bg-green-100 text-green-800 rounded-full text-sm;
        }
        .badge-danger {
            @apply inline-block px-3 py-1 bg-red-100 text-red-800 rounded-full text-sm;
        }
        .badge-warning {
            @apply inline-block px-3 py-1 bg-yellow-100 text-yellow-800 rounded-full text-sm;
        }
        .card-shadow {
            @apply bg-white rounded-lg shadow-md p-6;
        }
    </style>
</head>
<body class="bg-gray-50">
    <div class="flex h-screen">
        <!-- SIDEBAR -->
        <%- include('../layouts/sidebar', { user: user }) %>
        
        <!-- MAIN CONTENT -->
        <div class="flex-1 overflow-auto">
            <!-- TOP BAR -->
            <%- include('../layouts/topbar', { user: user }) %>
            
            <!-- PAGE CONTENT -->
            <main class="p-8">
                <%- body %>
            </main>
        </div>
    </div>
    
    <!-- Notification Toast Container -->
    <div id="toastContainer" class="fixed top-4 right-4 z-50"></div>
    
    <!-- Scripts -->
    <script src="/js/main.js"></script>
    <script src="/js/notifications.js"></script>
    <script src="/js/charts.js"></script>
</body>
</html>