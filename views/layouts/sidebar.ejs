<aside class="sidebar">
  <div class="sidebar-logo">
    <img src="/images/logo.jpg" alt="DESCO PREMIUM" class="sidebar-logo-img"
      onerror="this.style.display='none'; document.getElementById('sidebar-logo-fallback').style.display='flex'">
    <div id="sidebar-logo-fallback" style="display:none;align-items:center;gap:10px">
      <div class="sidebar-logo-icon"><i class="fas fa-chart-bar"></i></div>
      <div>
        <h1>DESCO</h1>
        <p>CRM Premium</p>
      </div>
    </div>
  </div>

  <div class="sidebar-user">
    <div class="sidebar-user-avatar"><%= user && user.fullName ? user.fullName.charAt(0).toUpperCase() : 'U' %></div>
    <div class="sidebar-user-info">
      <div class="name"><%= user ? user.fullName : '' %></div>
      <div class="role"><span class="role-dot"></span><%= user && user.role === 'admin' ? 'Administrator' : 'Manager' %></div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <a href="/" class="<%= activePage === 'dashboard' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-home"></i></span>
      <span class="nav-label">Dashboard</span>
    </a>
    <a href="/deals" class="<%= activePage === 'deals' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-handshake"></i></span>
      <span class="nav-label">Sdelkalar</span>
    </a>
    <a href="/clients" class="<%= activePage === 'clients' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-users"></i></span>
      <span class="nav-label">Mijozlar</span>
    </a>
    <a href="/tasks" class="<%= activePage === 'tasks' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-check-circle"></i></span>
      <span class="nav-label">Vazifalar</span>
    </a>
    <a href="/expenses" class="<%= activePage === 'expenses' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-receipt"></i></span>
      <span class="nav-label">Xarajatlar</span>
    </a>
    <a href="/instagram" class="<%= activePage === 'instagram' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fab fa-instagram" style="color:#E1306C"></i></span>
      <span class="nav-label">Instagram</span>
    </a>
    <div class="nav-divider"></div>
    <a href="/settings" class="<%= activePage === 'settings' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-cog"></i></span>
      <span class="nav-label">Sozlamalar</span>
    </a>
  </nav>

  <div class="sidebar-bottom">
    <button onclick="logout()">
      <i class="fas fa-sign-out-alt" style="width:20px;text-align:center;font-size:14px;color:var(--text-tertiary)"></i>
      <span>Chiqish</span>
    </button>
  </div>
</aside>
