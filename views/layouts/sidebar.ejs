<!-- SIDEBAR -->
<aside class="w-64 bg-gradient-to-b from-blue-700 to-blue-900 text-white p-6 shadow-lg">
    <!-- LOGO -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold flex items-center gap-2">
            <i class="fas fa-chart-line"></i>
            DESCO CRM
        </h1>
        <p class="text-blue-200 text-sm mt-1">Sales & Logistics</p>
    </div>
    
    <!-- USER INFO -->
    <div class="mb-8 p-4 bg-blue-600 rounded-lg">
        <p class="text-sm text-blue-100">Siz kirgan:</p>
        <p class="font-semibold text-white"><%= user.fullName %></p>
        <p class="text-xs text-blue-200 mt-1"><%= user.role === 'admin' ? '🧑‍💼 Admin' : '📊 Manager' %></p>
    </div>
    
    <!-- NAVIGATION -->
    <nav class="space-y-2">
        <a href="/" class="block px-4 py-2 rounded-lg hover:bg-blue-600 transition">
            <i class="fas fa-home w-5"></i> Dashboard
        </a>
        <a href="/deals" class="block px-4 py-2 rounded-lg hover:bg-blue-600 transition">
            <i class="fas fa-rocket w-5"></i> Sdelkalar
        </a>
        <a href="/clients" class="block px-4 py-2 rounded-lg hover:bg-blue-600 transition">
            <i class="fas fa-users w-5"></i> Kontaktlar
        </a>
        <a href="/expenses" class="block px-4 py-2 rounded-lg hover:bg-blue-600 transition">
            <i class="fas fa-truck w-5"></i> Xarajatlar
        </a>
        <a href="/tasks" class="block px-4 py-2 rounded-lg hover:bg-blue-600 transition">
            <i class="fas fa-tasks w-5"></i> Vazifalar
        </a>
        
        <% if (user.role === 'admin') { %>
        <hr class="border-blue-600 my-4">
        <a href="/settings" class="block px-4 py-2 rounded-lg hover:bg-blue-600 transition">
            <i class="fas fa-cog w-5"></i> Sozlamalar
        </a>
        <a href="/users" class="block px-4 py-2 rounded-lg hover:bg-blue-600 transition">
            <i class="fas fa-user-shield w-5"></i> Foydalanuvchilar
        </a>
        <% } %>
    </nav>
    
    <!-- LOGOUT -->
    <div class="mt-auto pt-4 border-t border-blue-600">
        <button onclick="logout()" class="w-full px-4 py-2 bg-red-600 hover:bg-red-700 rounded-lg transition text-left">
            <i class="fas fa-sign-out-alt w-5"></i> Chiqish
        </button>
    </div>
</aside>