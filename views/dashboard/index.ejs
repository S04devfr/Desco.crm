<%- include('../layouts/base', { 
    title: 'Dashboard - DESCO CRM',
    body: ` 
    <!-- PAGE HEADER -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-800">📊 Dashboard</h1>
        <p class="text-gray-600 mt-1">Xush kelibsiz, <%= user.fullName %>!</p>
    </div>
    
    <!-- KPI CARDS -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
        <!-- Total Orders -->
        <div class="card-shadow">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-gray-600 text-sm font-medium">📦 Jami Buyurtmalar</p>
                    <p class="text-2xl font-bold text-gray-800 mt-2" id="kpiOrders">0</p>
                </div>
                <div class="bg-blue-100 p-3 rounded-lg">
                    <i class="fas fa-box text-blue-600 text-xl"></i>
                </div>
            </div>
        </div>
        
        <!-- Total Revenue -->
        <div class="card-shadow">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-gray-600 text-sm font-medium">💰 Jami Tushum</p>
                    <p class="text-2xl font-bold text-green-600 mt-2" id="kpiRevenue">0</p>
                </div>
                <div class="bg-green-100 p-3 rounded-lg">
                    <i class="fas fa-dollar-sign text-green-600 text-xl"></i>
                </div>
            </div>
        </div>
        
        <!-- Outstanding Debt -->
        <div class="card-shadow">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-gray-600 text-sm font-medium">⚠️ Qarzdorlik</p>
                    <p class="text-2xl font-bold text-red-600 mt-2" id="kpiDebt">0</p>
                </div>
                <div class="bg-red-100 p-3 rounded-lg">
                    <i class="fas fa-exclamation-circle text-red-600 text-xl"></i>
                </div>
            </div>
        </div>
        
        <!-- Total Expenses -->
        <div class="card-shadow">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-gray-600 text-sm font-medium">🚗 Xarajatlar</p>
                    <p class="text-2xl font-bold text-orange-600 mt-2" id="kpiExpenses">0</p>
                </div>
                <div class="bg-orange-100 p-3 rounded-lg">
                    <i class="fas fa-car text-orange-600 text-xl"></i>
                </div>
            </div>
        </div>
        
        <!-- Net Profit -->
        <div class="card-shadow">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-gray-600 text-sm font-medium">📈 Sof Daromad</p>
                    <p class="text-2xl font-bold text-purple-600 mt-2" id="kpiProfit">0</p>
                </div>
                <div class="bg-purple-100 p-3 rounded-lg">
                    <i class="fas fa-chart-line text-purple-600 text-xl"></i>
                </div>
            </div>
        </div>
    </div>
    
    <!-- CHARTS & ANALYTICS -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        <!-- Sales by Manager -->
        <div class="card-shadow">
            <h3 class="text-lg font-bold text-gray-800 mb-4">👥 Manager bo'yicha Sotiladigan Mahsulot</h3>
            <canvas id="salesByManagerChart"></canvas>
        </div>
        
        <!-- Product Popularity -->
        <div class="card-shadow">
            <h3 class="text-lg font-bold text-gray-800 mb-4">⭐ Mahsulot Mashhurlig'i</h3>
            <canvas id="productPopularityChart"></canvas>
        </div>
    </div>
    
    <!-- TODAY'S TASKS -->
    <div class="card-shadow">
        <h3 class="text-lg font-bold text-gray-800 mb-4">📋 Bugungi Vazifalar</h3>
        <div id="todayTasksWidget" class="space-y-3 max-h-96 overflow-y-auto">
            <div class="text-center text-gray-500 py-8">Yuklanmoqda...</div>
        </div>
    </div>
    
    <script>
        // Load KPIs
        async function loadKPIs() {
            try {
                const response = await fetch('/api/dashboard/kpis');
                const data = await response.json();
                
                document.getElementById('kpiOrders').textContent = data.totalOrders;
                document.getElementById('kpiRevenue').textContent = formatCurrency(data.totalRevenue);
                document.getElementById('kpiDebt').textContent = formatCurrency(data.totalDebt);
                document.getElementById('kpiExpenses').textContent = formatCurrency(data.totalExpenses);
                document.getElementById('kpiProfit').textContent = formatCurrency(data.netProfit);
            } catch (error) {
                console.error('KPI loading error:', error);
            }
        }
        
        // Load Today's Tasks
        async function loadTodayTasks() {
            try {
                const response = await fetch('/api/dashboard/today-tasks');
                const tasks = await response.json();
                
                const tasksWidget = document.getElementById('todayTasksWidget');
                
                if (tasks.length === 0) {
                    tasksWidget.innerHTML = '<div class="text-center text-gray-500 py-8">Bugun vazifa yo\'q</div>';
                    return;
                }
                
                tasksWidget.innerHTML = tasks.map(task => \`
                    <div class="border-l-4 border-blue-500 pl-4 py-2">
                        <p class="font-semibold text-gray-800 text-sm\">${task.title}</p>
                        <p class="text-gray-600 text-xs mt-1">🕐 ${task.dueTime || 'Vaqt ko\'rsatilmagan'}</p>
                        <button onclick="completeTask(${task.id})" class="mt-2 px-3 py-1 bg-green-100 text-green-700 text-xs rounded hover:bg-green-200 transition">
                            ✓ Tugatish
                        </button>
                    </div>
                \`).join('');
                
                // Update badge
                document.getElementById('taskBadge').textContent = tasks.length;
                document.getElementById('taskBadge').classList.remove('hidden');
            } catch (error) {
                console.error('Tasks loading error:', error);
            }
        }
        
        // Load Charts
        async function loadCharts() {
            try {
                // Sales by Manager
                const salesResponse = await fetch('/api/dashboard/sales-by-manager');
                const salesData = await salesResponse.json();
                
                const ctx1 = document.getElementById('salesByManagerChart').getContext('2d');
                new Chart(ctx1, {
                    type: 'bar',
                    data: {
                        labels: salesData.map(d => d.manager),
                        datasets: [{
                            label: 'Sotuv Miqdori',
                            data: salesData.map(d => d.totalSales),
                            backgroundColor: 'rgba(59, 130, 246, 0.8)',
                            borderColor: 'rgb(59, 130, 246)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true } }
                    }
                });
                
                // Product Popularity
                const productsResponse = await fetch('/api/dashboard/product-popularity');
                const productsData = await productsResponse.json();
                
                const ctx2 = document.getElementById('productPopularityChart').getContext('2d');
                new Chart(ctx2, {
                    type: 'doughnut',
                    data: {
                        labels: productsData.map(d => d.product),
                        datasets: [{
                            data: productsData.map(d => d.count),
                            backgroundColor: [
                                'rgba(59, 130, 246, 0.8)',
                                'rgba(34, 197, 94, 0.8)',
                                'rgba(249, 115, 22, 0.8)',
                                'rgba(239, 68, 68, 0.8)',
                                'rgba(168, 85, 247, 0.8)'
                            ]
                        }]
                    },
                    options: { responsive: true }
                });
            } catch (error) {
                console.error('Chart loading error:', error);
            }
        }
        
        // Format currency
        function formatCurrency(value) {
            return new Intl.NumberFormat('uz-UZ', {
                style: 'currency',
                currency: 'UZS',
                minimumFractionDigits: 0
            }).format(value);
        }
        
        // Complete task
        async function completeTask(taskId) {
            try {
                await fetch('/api/tasks/' + taskId + '/complete', { method: 'PATCH' });
                loadTodayTasks();
                showToast('✅ Vazifa tugatildi!', 'success');
            } catch (error) {
                console.error('Error completing task:', error);
            }
        }
        
        // Initialize
        loadKPIs();
        loadTodayTasks();
        loadCharts();
        
        // Refresh every 5 minutes
        setInterval(() => {
            loadKPIs();
            loadTodayTasks();
        }, 5 * 60 * 1000);
    </script>
    ` 
}) %>