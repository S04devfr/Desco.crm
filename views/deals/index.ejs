  clearTimeout(_searchTimer);
  _searchTimer = setTimeout(loadDeals, 350);
});
document.getElementById('filterStage').addEventListener('change', loadDeals);
document.getElementById('filterManager').addEventListener('change', loadDeals);

// ── bfcache fix ────────────────────────────────────────────────
window.addEventListener('pageshow', e => { if (e.persisted) loadAll(); });

// ══════════════════════════════════════════════════════════════
//  START — run immediately. This <script> executes after all the
//  HTML above it (inputs, selects, kanban board) is already parsed
//  into the DOM, so there is no need to wait for window 'load'.
//  IMPORTANT: do NOT gate this on window.addEventListener('load', ...) —
//  'load' only fires once EVERY page resource finishes (including the
//  external Font Awesome / Chart.js CDN <link>/<script> tags in the
//  layout's <head>). If either CDN is slow, blocked, or unreachable,
//  'load' can be delayed indefinitely or never fire at all, which
//  permanently freezes the Kanban board on the static "Yuklanmoqda…"
//  placeholder — this was the actual root cause of the infinite
//  loading bug. _toast() already falls back gracefully if main.js's
//  showToast() isn't defined yet, so there's no real dependency on
//  any other script having finished loading first.
// ══════════════════════════════════════════════════════════════
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init);
} else {
  init();
}

// ── Real-Time Lead Routing (WebSocket) ─────────────────────────
const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
const ws = new WebSocket(protocol + '//' + window.location.host);
ws.onmessage = async (event) => {
  try {
    const data = JSON.parse(event.data);
    const myId = <%= typeof user !== 'undefined' && user ? user.id : 'null' %>;
    
    if (data.type === 'deal_updated' && data.dealId) {
      const res = await fetch('/api/deals/' + data.dealId);
      if (res.ok) {
        const updatedDeal = await res.json();
        // Agar sdelka o'zlashtirilgan bo'lsa va u meniki bo'lmasa -> Ekrandan o'chiramiz!
        if (updatedDeal.managerId && updatedDeal.managerId !== myId) {
          _deals = _deals.filter(d => d.id !== updatedDeal.id);
        } else {
          // Aks holda uni yangilaymiz yoki qo'shamiz
          const idx = _deals.findIndex(d => d.id === updatedDeal.id);
          if (idx >= 0) _deals[idx] = updatedDeal;
          else _deals.push(updatedDeal);
        }
        
        if (document.getElementById('viewKanban').classList.contains('active')) {
          renderKanban();
        } else {
          renderTable();
        }
      }
    }
    
    if (data.type === 'deal_deleted' && data.dealId) {
      _deals = _deals.filter(d => d.id !== data.dealId);
      if (document.getElementById('viewKanban').classList.contains('active')) renderKanban();
      else renderTable();
    }
  } catch (e) {
    console.error('Socket error:', e);
  }
};
// ───────────────────────────────────────────────────────────────
  </script>
  <%- include('../layouts/footer') %>