          ${sDeals.length ? sDeals.map(d => dcardHtml(d)).join('') : '<div class="kb-empty">Sdelka yo\'q</div>'}
        </div>
        <div class="kb-addbtn-wrap">
          <button class="kb-addbtn" onclick="openDealModal(${s.id})">
            <i class="fas fa-plus"></i> Add Card
          </button>
