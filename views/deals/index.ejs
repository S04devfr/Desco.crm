    ` : '';

    return `
      <div class="kb-col${editable ? ' editing' : ''}" style="--_sc:${s.color||'#007AFF'}">
        <div class="kb-col-hdr"
          ${editable ? `draggable="true" ondragstart="onColDragStart(event,${s.id})" ondragend="onColDragEnd(event)" ondragover="onColDragOver(event)" ondragleave="onColDragLeave(event)" ondrop="onColDrop(event,${s.id})"` : ''}>${hdrHtml}</div>
