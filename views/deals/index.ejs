function openPipelineMgr() {
  document.getElementById('pmgrModal').classList.remove('hidden');
  _pmgrPid = _activePid;
  renderPmgrPipelines();
  renderPmgrStages();
}

function closePipelineMgr() {
  document.getElementById('pmgrModal').classList.add('hidden');
