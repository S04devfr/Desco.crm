      <!-- Tahrirlash tugmasi -->
      <div onclick="event.stopPropagation(); openDealModal(null, ${d.id})" style="position:absolute; top:10px; right:12px; color:var(--text-tertiary); cursor:pointer; padding: 4px; border-radius: 4px; transition: background 0.2s;" onmouseover="this.style.background='var(--glass-bg)'; this.style.color='var(--accent)'" onmouseout="this.style.background='transparent'; this.style.color='var(--text-tertiary)'">
        <i class="fas fa-edit"></i>
      </div>

      <div class="dcard-header" style="margin-bottom:8px; display:flex; flex-direction:column; align-items:flex-start; padding-right:24px;">
        <span class="dcard-badge" style="background:${sc}1A; color:${sc}; padding:2px 6px; font-size:9.5px; border-radius:4px; font-weight:700; text-transform:uppercase; margin-bottom: 6px;">${sl}</span>
        <div style="font-weight:600; font-size:14px; color:var(--text-primary); line-height:1.3">${_esc(d.productName||d.name)}</div>
      </div>
      
      ${clientHtml}
