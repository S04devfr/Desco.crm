  pmgrHideStageForm();
}

function renderPmgrPipelines() {
  const list = document.getElementById('pmgrPipelineList');
  list.innerHTML = _pipelines.map(p => `
    <div class="pmgr-pitem${p.id===_pmgrPid?' active':''}" onclick="pmgrSelectPipeline(${p.id})">
      <div style="width:9px;height:9px;border-radius:50%;background:${p.color||'#007AFF'};flex-shrink:0"></div>
      <span style="flex:1;font-size:13px">${_esc(p.name)}${p.isDefault?' <small style=\\"color:var(--text-tertiary)\\">default</small>':''}</span>
      <div style="display:flex;gap:3px">
        <button class="btn btn-ghost btn-icon" style="padding:2px 5px;font-size:11px" onclick="event.stopPropagation();pmgrEditPipeline(${p.id})"><i class="fas fa-edit"></i></button>
        <button class="btn btn-ghost btn-icon text-danger" style="padding:2px 5px;font-size:11px" onclick="event.stopPropagation();pmgrDeletePipeline(${p.id})"><i class="fas fa-trash"></i></button>
      </div>
    </div>
  `).join('') || '<div style="color:var(--text-tertiary);font-size:13px;padding:8px">Voronka yo\'q</div>';
}

function renderPmgrStages() {
  const p = _pipelines.find(x => x.id === _pmgrPid);
  const stages = p ? (p.stages||[]) : [];
  document.getElementById('pmgrStageTitle').textContent = p ? p.name + ' — bosqichlar' : 'Voronka tanlanmagan';
  document.getElementById('pmgrAddStageBtn').style.display = p ? '' : 'none';
  document.getElementById('pmgrStageList').innerHTML = stages.map(s => `
    <div class="pmgr-sitem">
      <div style="width:9px;height:9px;border-radius:50%;background:${s.color||'#007AFF'}"></div>
      <span style="font-size:13px">${_esc(s.name)}</span>
      <div class="sitem-actions">
        <button class="btn btn-ghost btn-icon btn-sm" onclick="pmgrEditStage(${s.id},'${_esc(s.name)}','${s.color||'#007AFF'}')"><i class="fas fa-edit"></i></button>
        <button class="btn btn-ghost btn-icon btn-sm text-danger" onclick="pmgrDeleteStage(${s.id})"><i class="fas fa-trash"></i></button>
      </div>
    </div>
  `).join('') || '<div style="color:var(--text-tertiary);font-size:13px;padding:8px">Bosqich yo\'q</div>';
}

function pmgrSelectPipeline(id) {
  _pmgrPid = id;
  pmgrHideStageForm();
  renderPmgrPipelines();
  renderPmgrStages();
}

function pmgrNewPipeline() {
  document.getElementById('pmgr-pId').value = '';
  document.getElementById('pmgr-pName').value = '';
  document.getElementById('pmgr-pColor').value = '#007AFF';
  document.getElementById('pmgrPipelineForm').classList.remove('hidden');
  setTimeout(() => document.getElementById('pmgr-pName').focus(), 50);
}

function pmgrEditPipeline(id) {
  const p = _pipelines.find(x => x.id === id);
  if (!p) return;
  document.getElementById('pmgr-pId').value = id;
  document.getElementById('pmgr-pName').value = p.name;
  document.getElementById('pmgr-pColor').value = p.color || '#007AFF';
  document.getElementById('pmgrPipelineForm').classList.remove('hidden');
  setTimeout(() => document.getElementById('pmgr-pName').focus(), 50);
}

function pmgrHidePipelineForm() {
  document.getElementById('pmgrPipelineForm').classList.add('hidden');
}

async function pmgrSavePipeline() {
  const id    = document.getElementById('pmgr-pId').value;
  let name  = document.getElementById('pmgr-pName').value.trim();
  const color = document.getElementById('pmgr-pColor').value;
  if (!name) { _toast('Nom majburiy','error'); return; }
  
  const isNasiyaPage = window.location.pathname.includes('/nasiya');
  if (!id && isNasiyaPage && !name.toLowerCase().includes('nasiya')) {
    name = "Nasiya - " + name;
  }
  try {
    const data = await apiFetch(id ? '/api/pipelines/'+id : '/api/pipelines', {
      method: id ? 'PATCH' : 'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ name, color })
    });
    _toast(id ? 'Yangilandi' : "Qo'shildi", 'success');
    pmgrHidePipelineForm();
    await loadPipelines();
    if (!id && data.id) { _pmgrPid = data.id; }
    renderPmgrPipelines();
    renderPmgrStages();
  } catch(e) { _toast(e.message,'error'); }
}

async function pmgrDeletePipeline(id) {
  if (!confirm("Voronkani o'chirishni tasdiqlaysizmi? Barcha bosqichlar ham o'chadi.")) return;
  try {
    await apiFetch('/api/pipelines/' + id, { method:'DELETE' });
    _toast("O'chirildi",'success');
    await loadPipelines();
    if (_pmgrPid === id) _pmgrPid = _pipelines[0]?.id || null;
    if (_activePid === id) { _activePid = _pipelines[0]?.id || null; updateActiveStages(); }
    renderPmgrPipelines();
    renderPmgrStages();
  } catch(e) { _toast(e.message,'error'); }
}

function pmgrNewStage() {
  if (!_pmgrPid) { _toast('Avval voronka tanlang','error'); return; }
  document.getElementById('pmgr-sId').value = '';
  document.getElementById('pmgr-sName').value = '';
  document.getElementById('pmgr-sColor').value = '#007AFF';
  document.getElementById('pmgrStageForm').classList.remove('hidden');
  setTimeout(() => document.getElementById('pmgr-sName').focus(), 50);
}

function pmgrEditStage(id, name, color) {
  document.getElementById('pmgr-sId').value = id;
  document.getElementById('pmgr-sName').value = name;
  document.getElementById('pmgr-sColor').value = color;
  document.getElementById('pmgrStageForm').classList.remove('hidden');
  setTimeout(() => document.getElementById('pmgr-sName').focus(), 50);
}

function pmgrHideStageForm() {
  document.getElementById('pmgrStageForm').classList.add('hidden');
}

async function pmgrSaveStage() {
  const sid   = document.getElementById('pmgr-sId').value;
  const name  = document.getElementById('pmgr-sName').value.trim();
  const color = document.getElementById('pmgr-sColor').value;
  if (!name) { _toast('Nom majburiy','error'); return; }
  if (!_pmgrPid) { _toast('Voronka tanlanmagan','error'); return; }
  try {
    const url = sid
      ? '/api/pipelines/' + _pmgrPid + '/stages/' + sid
      : '/api/pipelines/' + _pmgrPid + '/stages';
    await apiFetch(url, {
      method: sid ? 'PATCH' : 'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ name, color })
    });
    _toast(sid ? 'Yangilandi' : "Qo'shildi",'success');
    pmgrHideStageForm();
    await loadPipelines();
    renderPmgrPipelines();
    renderPmgrStages();
  } catch(e) { _toast(e.message,'error'); }
}

async function pmgrDeleteStage(id) {
  if (!confirm("Bosqichni o'chirishni tasdiqlaysizmi?")) return;
  try {
    await apiFetch('/api/pipelines/' + _pmgrPid + '/stages/' + id, { method:'DELETE' });
    _toast("O'chirildi",'success');
    await loadPipelines();
    renderPmgrPipelines();
    renderPmgrStages();
    await loadDeals();
  } catch(e) { _toast(e.message,'error'); }
}

