            style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-tertiary);margin-bottom:4px">
            Bosqich tanlanmagan</div>
          <div id="pmgrStageList"></div>
          <div id="pmgrStageForm" class="hidden"
            style="background:var(--bg-secondary);border-radius:8px;padding:10px;border:1px solid var(--glass-border);margin-top:4px">
            <input type="hidden" id="pmgr-sId">
            <input type="text" id="pmgr-sName" class="form-control" placeholder="Bosqich nomi"
              style="height:32px;font-size:12px;margin-bottom:6px">
