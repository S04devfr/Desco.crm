// ── Drag & drop ────────────────────────────────────────────────
function onDragStart(e, id) {
  _dragId = id;
  e.currentTarget.classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
}
function onDragEnd(e) {
  e.currentTarget.classList.remove('dragging');
  const ph = document.getElementById('kbDropPlaceholder');
  if (ph) ph.remove();
}

// Finds the card the cursor is currently hovering above, so the drop
// placeholder bounding box can be inserted at the exact intended position
// within the column rather than always at the end.
function _dragAfterElement(container, y) {
  const cards = [...container.querySelectorAll('.dcard:not(.dragging)')];
  return cards.reduce((closest, child) => {
    const box = child.getBoundingClientRect();
    const offset = y - box.top - box.height / 2;
    if (offset < 0 && offset > closest.offset) return { offset, element: child };
    return closest;
  }, { offset: Number.NEGATIVE_INFINITY, element: null }).element;
}

function _ensureDropPlaceholder() {
  let ph = document.getElementById('kbDropPlaceholder');
  if (!ph) {
    ph = document.createElement('div');
    ph.id = 'kbDropPlaceholder';
    ph.className = 'kb-drop-placeholder';
  }
  return ph;
}

function onDragOver(e) {
  e.preventDefault();
  e.currentTarget.classList.add('drag-over');
  const container = e.currentTarget;
  const ph = _ensureDropPlaceholder();
  const afterEl = _dragAfterElement(container, e.clientY);
  if (afterEl) container.insertBefore(ph, afterEl);
  else container.appendChild(ph);
}
function onDragLeave(e) {
  e.currentTarget.classList.remove('drag-over');
  // Only drop the placeholder once the cursor truly leaves this column
  // (not just moving over a child card inside it).
  if (!e.relatedTarget || !e.currentTarget.contains(e.relatedTarget)) {
    const ph = document.getElementById('kbDropPlaceholder');
    if (ph) ph.remove();
  }
}
async function onDrop(e, stageId) {
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  const ph = document.getElementById('kbDropPlaceholder');
  if (ph) ph.remove();
  if (!_dragId) return;
  const dealId = _dragId;
  _dragId = null;

  const deal = _deals.find(d => d.id === dealId);
  if (!deal) return;
  const newStageId = stageId || null;
  if (deal.stageId === newStageId) return;

  // Mock columns (negative ids) are a rendering-only placeholder — there
  // is no real PipelineStage row to move into, so block the drop before
  // ever touching local state or the network.
  if (_usingMockStages && newStageId !== null && newStageId < 0) {
    _toast("Bu namuna bosqich — avval voronkani sozlang", 'error');
    return;
  }

  // ── Optimistic UI update ──────────────────────────────────────
  // Move the card and recalc column counts/totals INSTANTLY, before
  // the network call even starts. Persist to the DB in the background;
  // if it fails, move the card back and show a toast — no full board
  // re-fetch needed in either path.
  const previousStageId = deal.stageId;
  deal.stageId = newStageId;
  renderKanban();

  try {
    const updated = await apiFetch('/api/deals/' + dealId + '/stage', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ stageId: newStageId })
    });
    // Merge server-confirmed fields (stage relation, updatedAt, etc.)
    // into the local deal object without re-fetching the whole board.
    Object.assign(deal, updated);
    _toast('Bosqich o\'zgartirildi', 'success');

    // Avtomatizatsiya: Vazifalar bosqichiga o'tganda avtomatik Vazifa yaratish
    const targetStage = _stages.find(s => s.id === newStageId);
    if (targetStage && targetStage.name && targetStage.name.toLowerCase() === 'vazifalar') {
      const clientInfo = deal.client ? (deal.client.name + ' ' + (deal.client.phone || '')).trim() : "Mijoz noma'lum";
      const desc = 'Mahsulot: ' + (deal.productName || deal.name || 'Noma\'lum') + '\\nMijoz: ' + clientInfo;
      const tomorrow = new Date();
      tomorrow.setDate(tomorrow.getDate() + 1);
      
      apiFetch('/api/tasks', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: 'Qayta aloqa',
          description: desc,
          dueDate: tomorrow.toISOString().substring(0,10),
          dealId: deal.id
        })
      }).then(() => {
        _toast('Vazifa avtomatik yaratildi: Qayta aloqa', 'success');
      }).catch(err => {
        console.error('Vazifa avtomatizatsiya xatosi:', err);
      });
    }

  } catch (err) {
    // Roll back to the previous stage and re-render.
    deal.stageId = previousStageId;
    renderKanban();
    _toast(err.message, 'error');
  }
}

// ── Won / Lost bottom drop zones ────────────────────────────────
function onZoneDragOver(e) {
  e.preventDefault();
  e.currentTarget.classList.add('rzone-over');
}
function onZoneDragLeave(e) {
  e.currentTarget.classList.remove('rzone-over');
}
async function onZoneDrop(e, outcome) {
  e.preventDefault();
  e.currentTarget.classList.remove('rzone-over');
  if (!_dragId) return;
  const dealId = _dragId;
  _dragId = null;

  const deal = _deals.find(d => d.id === dealId);
  if (!deal) return;

  // If a real stage matching this outcome exists in the active pipeline
  // (e.g. "Yutilgan" / "Yo'qotilgan"), move the card there too — otherwise
  // just clear the stage. Either way the source column's count/total
  // recompute immediately since the card leaves it.
  const matchNames = outcome === 'won'
    ? ['yutilgan', "g'olib", 'won', 'muvaffaqiyat']
    : ["yo'qotilgan", 'yoqotilgan', 'lost', 'real emas'];
  const targetStage = (!_usingMockStages ? _stages : [])
    .find(s => matchNames.some(n => (s.name || '').toLowerCase().includes(n)));
  const newStageId = targetStage ? targetStage.id : null;

  const previousStageId = deal.stageId;
  const previousStatus = deal.status;
  deal.status = outcome;
  deal.stageId = newStageId;
  renderKanban();

  try {
    const updated = await apiFetch('/api/deals/' + dealId, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: outcome, stageId: newStageId })
    });
    Object.assign(deal, updated);
    _toast(outcome === 'won' ? 'Sdelka muvaffaqiyatli yopildi' : 'Sdelka real emas deb belgilandi', 'success');
  } catch (err) {
    deal.stageId = previousStageId;
    deal.status = previousStatus;
    renderKanban();
    _toast(err.message, 'error');
  }
}

// ── Settings gear → board-wide column Edit Mode ─────────────────
function toggleEditMode() {
  _editMode = !_editMode;
  document.getElementById('btnEditMode').classList.toggle('active', _editMode);
  document.getElementById('kbEditBanner').classList.toggle('hidden', !_editMode);
  renderKanban();
}

async function renameStage(stageId, name) {
  name = (name || '').trim();
  const stage = _stages.find(s => s.id === stageId);
  if (!name || _usingMockStages) { renderKanban(); return; }
  if (stage && stage.name === name) return;
  try {
    await apiFetch('/api/pipelines/' + _activePid + '/stages/' + stageId, {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name })
    });
    if (stage) stage.name = name;
    _toast('Nom yangilandi', 'success');
    await loadPipelines();
    renderKanban();
  } catch (e) { _toast(e.message, 'error'); renderKanban(); }
}

async function deleteStageQuick(stageId) {
  if (_usingMockStages) { _toast('Avval voronkani sozlang', 'error'); return; }
  if (!confirm("Bosqichni o'chirishni tasdiqlaysizmi?")) return;
  try {
    await apiFetch('/api/pipelines/' + _activePid + '/stages/' + stageId, { method: 'DELETE' });
    _toast("O'chirildi", 'success');
    await loadPipelines();
    await loadDeals();
  } catch (e) { _toast(e.message, 'error'); }
}

async function addStageQuick() {
  if (_usingMockStages) { _toast('Avval voronkani sozlang', 'error'); return; }
  const name = prompt('Yangi bosqich nomi:');
  if (!name || !name.trim()) return;
  try {
    await apiFetch('/api/pipelines/' + _activePid + '/stages', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: name.trim() })
    });
    _toast("Bosqich qo'shildi", 'success');
    await loadPipelines();
    renderKanban();
  } catch (e) { _toast(e.message, 'error'); }
}

// ── Column drag-and-drop reordering (Edit Mode only) ─────────────
function onColDragStart(e, stageId) {
  if (!_editMode) return;
  _colDragId = stageId;
  e.stopPropagation();
  e.currentTarget.classList.add('col-dragging');
  e.dataTransfer.effectAllowed = 'move';
}
function onColDragEnd(e) {
  e.currentTarget.classList.remove('col-dragging');
}
function onColDragOver(e) {
  if (!_editMode || _colDragId == null) return;
  e.preventDefault();
  e.stopPropagation();
  e.currentTarget.classList.add('col-drag-over');
}
function onColDragLeave(e) {
  e.currentTarget.classList.remove('col-drag-over');
}
async function onColDrop(e, targetStageId) {
  if (!_editMode) return;
  e.preventDefault();
  e.stopPropagation();
  e.currentTarget.classList.remove('col-drag-over');
  const dragId = _colDragId;
  _colDragId = null;
  if (dragId == null || dragId === targetStageId || _usingMockStages) return;

  const ids = _stages.map(s => s.id);
  const fromIdx = ids.indexOf(dragId);
  const toIdx = ids.indexOf(targetStageId);
  if (fromIdx === -1 || toIdx === -1) return;
  ids.splice(fromIdx, 1);
  ids.splice(toIdx, 0, dragId);

  // Optimistic reorder
  _stages = ids.map(id => _stages.find(s => s.id === id)).filter(Boolean);
  renderKanban();

  try {
    await apiFetch('/api/pipelines/' + _activePid + '/stages/reorder', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids })
    });
    await loadPipelines();
    renderKanban();
  } catch (err) {
    _toast(err.message, 'error');
    await loadPipelines();
    renderKanban();
  }
}

// ── Quick Add (Быстрое добавление) — first Kanban column ────────
function toggleQuickAdd() {
  _qaddOpen = !_qaddOpen;
  renderKanban();
  if (_qaddOpen) setTimeout(() => { const el = document.getElementById('qa-name'); if (el) el.focus(); }, 50);
}

async function submitQuickAdd() {
  const contactName    = document.getElementById('qa-contactName').value.trim();
  const contactPhone   = document.getElementById('qa-contactPhone').value.trim();
  const nameEl         = document.getElementById('qa-name');
  const name           = nameEl ? nameEl.value.trim() : '';
  const city           = document.getElementById('qa-city').value.trim();
  const notes          = document.getElementById('qa-notes').value.trim();

  if (!contactName) { _toast('Mijoz ismi majburiy', 'error'); document.getElementById('qa-contactName').focus(); return; }
  if (!contactPhone) { _toast('Telefon raqami majburiy', 'error'); document.getElementById('qa-contactPhone').focus(); return; }
  if (!name) { _toast('Mahsulot nomi majburiy', 'error'); if (nameEl) nameEl.focus(); return; }

  const firstStage = (!_usingMockStages && _stages.length) ? _stages[0].id : null;

  const btn = document.getElementById('qaSaveBtn');
  if (btn) btn.disabled = true;
  try {
    await apiFetch('/api/deals', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        productName: name,
        amount: 0,
        stageId: firstStage,
        pipelineId: _activePid,
        contactName: contactName,
        contactPhone: contactPhone,
        city: city || null,
        notes: notes || null
      })
    });
    _toast("Sdelka qo'shildi", 'success');
    _qaddOpen = false;
    await loadDeals();
  } catch (e) { _toast(e.message, 'error'); }
  finally { if (btn) btn.disabled = false; }
}

function callbackRedirect(dealId, dealTitle, clientId) {
  const params = new URLSearchParams();
  if (dealId) params.set('dealId', dealId);
  if (dealTitle) params.set('dealTitle', dealTitle);
  if (clientId) params.set('clientId', clientId);
  window.location.href = '/tasks?' + params.toString();
}

// ── Deal modal ─────────────────────────────────────────────────
function openDealModal(defaultStageId, editId) {
  const modal = document.getElementById('dealModal');
  const setVal = (id, val) => { const el = document.getElementById(id); if (el) el.value = val !== undefined && val !== null ? val : ''; };

  setVal('f-id', editId || '');
  setVal('f-name', '');
  setVal('f-amount', '');
  setVal('f-paidAmount', '');
  setVal('f-clientId', '');
  setVal('f-deadline', '');
  setVal('f-notes', '');
  setVal('f-contactName', '');
  setVal('f-contactPhone', '');
  setVal('f-city', '');
  
  const titleEl = document.getElementById('dealModalTitle');
  if (titleEl) titleEl.textContent = editId ? 'Sdelkani tahrirlash' : 'Yangi sdelka';

  const stageEl = document.getElementById('f-stageId');
  if (stageEl) {
    if (defaultStageId && !_usingMockStages) {
      stageEl.value = defaultStageId;
    } else if (!editId && _stages.length && !_usingMockStages) {
      stageEl.value = _stages[0].id;
    } else {
      stageEl.value = '';
    }
  }

  if (editId) {
    const deal = _deals?.find(d => d?.id === editId);
    if (deal) {
      setVal('f-name', deal?.productName || deal?.name || '');
      setVal('f-contactName', deal?.client?.name || '');
      setVal('f-contactPhone', deal?.client?.phone || '');
      setVal('f-city', deal?.client?.city || '');
      setVal('f-amount', deal?.amount || '');
      setVal('f-paidAmount', deal?.paidAmount || '');
      setVal('f-clientId', deal?.clientId || '');
      if (stageEl) stageEl.value = deal?.stageId || '';
      setVal('f-notes', deal?.notes || '');

      // Claim logic
      if (!deal.managerId || (deal.stage && deal.stage.name && deal.stage.name.toLowerCase().includes('yangi'))) {
        apiFetch(`/api/deals/${deal.id}/claim`, { method: 'POST' })
          .then(() => {
            if (typeof _toast === 'function') _toast("Sdelka sizga biriktirildi", "success");
            // Optionally reload to reflect ownership changes
          })
          .catch(e => { /* Ignore errors if already claimed */ });
      }
    }
  }

  if (modal) modal.classList.remove('hidden');
  setTimeout(() => { const el = document.getElementById('f-name'); if (el) el.focus(); }, 100);
}

function closeDealModal() {
  document.getElementById('dealModal').classList.add('hidden');
}

async function saveDeal() {
  const id    = document.getElementById('f-id').value;
  const name  = document.getElementById('f-name').value.trim();
  if (!name) { _toast('Sdelka nomi majburiy', 'error'); document.getElementById('f-name').focus(); return; }

  // Belt-and-suspenders: never send a negative (mock/local-only) stage id
  // to the API, even if some UI path slipped one into the form.
  let rawStageId = document.getElementById('f-stageId').value ? Number(document.getElementById('f-stageId').value) : null;
  if (rawStageId !== null && rawStageId <= 0) rawStageId = null;

  const body = {
    productName: name,
    contactName: document.getElementById('f-contactName').value.trim() || null,
    contactPhone: document.getElementById('f-contactPhone').value.trim() || null,
    city:        document.getElementById('f-city').value.trim() || null,
    amount:      Number(document.getElementById('f-amount').value) || 0,
    paidAmount:  Number(document.getElementById('f-paidAmount').value) || 0,
    clientId:    document.getElementById('f-clientId').value ? Number(document.getElementById('f-clientId').value) : null,
    stageId:     rawStageId,
    pipelineId:  _activePid,
    notes:       document.getElementById('f-notes').value.trim() || null,
  };

  const btn = document.getElementById('dealSaveBtn');
  btn.disabled = true;
  try {
    if (id) {
      await apiFetch('/api/deals/' + id, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
      _toast('Yangilandi', 'success');
    } else {
      await apiFetch('/api/deals', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
      _toast("Qo'shildi", 'success');
    }
    closeDealModal();
    await loadDeals();
  } catch(e) { _toast(e.message, 'error'); }
  finally { btn.disabled = false; }
}

