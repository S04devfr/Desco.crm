      <div style="margin-top:10px; display:flex; gap:6px;">
        <button class="btn btn-secondary btn-sm" style="flex:1; font-size:11.5px; padding: 6px 0;" onclick="event.stopPropagation(); callbackRedirect(${d.id}, '${_esc(d.productName||d.name)}', ${d.clientId})">
          <i class="fas fa-headset"></i> Qayta aloqa
