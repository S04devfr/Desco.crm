function closeDetail() {
  document.getElementById('detailModal').classList.add('hidden');
  _detailId = null;
}

async function createTaskForDeal(dealId, dealTitle) {
  try {
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    
    await apiFetch('/api/tasks', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        title: dealTitle + ' bo\'yicha qayta aloqa',
        description: 'Mijoz bilan sdelka bo\'yicha bog\'lanish kerak',
        dueDate: tomorrow.toISOString().substring(0,10),
        dealId: dealId
      })
    });
    _toast('Vazifa muvaffaqiyatli yaratildi', 'success');
  } catch(e) {
    _toast(e.message, 'error');
  }
}

async function addComment(dealId) {
  const input = document.getElementById('newCommentInput');
  const text = input ? input.value.trim() : '';
  if (!text) return;

  try {
    const btn = input.nextElementSibling;
    btn.disabled = true;
    await apiFetch('/api/deals/' + dealId + '/comments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text })
    });
    input.value = '';
    // Reload detail to show the new comment
    await openDetail(dealId);
  } catch(e) {
    _toast(e.message, 'error');
  }
}

function editCurrentDeal() {
  if (!_detailId) return;
  closeDetail();
  openDealModal(null, _detailId);
}

function editDealDirectly(id) {
  openDealModal(null, id);
}

async function deleteCurrentDeal() {
  if (!_detailId) return;
  if (!confirm("Sdelkani o'chirishni tasdiqlaysizmi?")) return;
  try {
    await apiFetch('/api/deals/' + _detailId, { method:'DELETE' });
    _toast("O'chirildi", 'success');
    closeDetail();
    await loadDeals();
  } catch(e) { _toast(e.message, 'error'); }
}

async function deleteDeal(id) {
  if (!confirm("Sdelkani o'chirishni tasdiqlaysizmi?")) return;
  try {
    await apiFetch('/api/deals/' + id, { method:'DELETE' });
    _toast("O'chirildi", 'success');
    await loadDeals();
  } catch(e) { _toast(e.message, 'error'); }
}

async function moveDeal(dealId, stageId) {
  if (_usingMockStages && stageId !== null && stageId !== undefined && Number(stageId) < 0) {
    _toast("Bu namuna bosqich — avval voronkani sozlang", 'error');
    return;
  }
  try {
    await apiFetch('/api/deals/' + dealId + '/stage', {
      method:'PATCH', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ stageId })
    });
    _toast('Bosqich o\'zgartirildi', 'success');
    closeDetail();
    await loadDeals();
  } catch(e) { _toast(e.message, 'error'); }
}

