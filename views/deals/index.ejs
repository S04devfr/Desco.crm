  <script>
    // ════════════════════════════════════════════════════════════════
    //  DESCO CRM — Sdelkalar v4 (self-contained, amoCRM uslubida)
    //  Barcha helper funksiyalar INLINE — main.js ga bog'liq EMAS
    // ════════════════════════════════════════════════════════════════

    // ── Inline helpers (main.js ga bog'liq emas) ──────────────────
    function _esc(s) {
      if (s == null) return '';
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function _fmt(v, short) {
      const n = Number(v) || 0;
      if (!short) return n.toLocaleString('uz-UZ') + " so'm";
      if (n >= 1e9) return (n / 1e9).toFixed(1).replace('.0', '') + " mlrd";
      if (n >= 1e6) return (n / 1e6).toFixed(1).replace('.0', '') + " mln";
      if (n >= 1e3) return (n / 1e3).toFixed(0) + " ming";
      return String(n);
    }

    function _date(d) {
      if (!d) return '';
      const dt = new Date(d);
      if (isNaN(dt)) return '';
      return dt.toLocaleDateString('uz-UZ', { day: '2-digit', month: '2-digit', year: '2-digit' });
    }

    function _toast(msg, type) {
      // Use main.js showToast if available, otherwise fallback
      if (typeof showToast === 'function') {
        showToast(msg, type);
        return;
      }
      const c = document.getElementById('toastContainer');
      if (!c) return;
      const t = document.createElement('div');
      t.className = 'toast toast-' + (type || 'info');
      t.innerHTML = '<span>' + _esc(msg) + '</span>';
      t.style.cssText = 'margin-top:8px;padding:10px 16px;border-radius:8px;font-size:13px;color:#fff;background:' +
        (type === 'error' ? '#FF3B30' : type === 'success' ? '#34C759' : '#007AFF');
      c.appendChild(t);
      setTimeout(() => t.remove(), 3500);
    }

    // ── Globals ────────────────────────────────────────────────────
    const USER_ROLE = '${user && user.role ? user.role : "manager"}';
    const CURRENT_USER_ID = parseInt('${user ? user.id : 0}');

    // ── State ──────────────────────────────────────────────────────
    let _pipelines = [];
    let _stages = [];   // active pipeline stages
    let _deals = [];
    let _managers = [];
    let _clients = [];
    let _activePid = null;
    let _view = 'kanban';
    let _detailId = null;
    let _dragId = null;
    let _pmgrPid = null;   // pipeline manager selected pipeline
    let _searchTimer = null;
    let _usingMockStages = false;  // true when rendering the local fallback grid below
    let _editMode = false;  // Settings gear → board-wide column edit mode
    let _qaddOpen = false;  // Quick Add panel open/closed (first column)
    let _colDragId = null;   // stageId currently being dragged (column reorder)
    let _dropPlaceholderStageId = null;  // which column currently shows the drop placeholder

    // Local fallback stages — used ONLY for rendering when the active pipeline
    // has no real stages yet (empty DB, freshly created pipeline, deleted
    // stages, etc). These have negative ids so they can never collide with a
    // real PipelineStage row, and the backend's own id<=0 validation in
    // PATCH /api/deals/:id/stage will reject any attempt to persist a deal
    // into one — onDrop()/moveDeal() also short-circuit before even trying,
    // so the user always sees a working grid instead of a dead "Bosqichlar
    // yo'q" screen, but can never silently lose a drag-drop into a stage
    // that doesn't really exist in the database.
    const DEFAULT_MOCK_STAGES = [
      { id: -1, name: 'Yangi', color: '#1565C0', order: 1, __mock: true },
      { id: -2, name: 'Muzokaralar', color: '#F57F17', order: 2, __mock: true },
      { id: -3, name: 'Taklif', color: '#512DA8', order: 3, __mock: true },
      { id: -4, name: 'Yutilgan', color: '#2E7D32', order: 4, __mock: true },
      { id: -5, name: "Yo'qotilgan", color: '#C62828', order: 5, __mock: true },
    ];

    // ── Init (called AFTER window.load = main.js guaranteed ready) ─
    async function init() {
      try {
        await loadAll();
        initWebSocket();
        
        const params = new URLSearchParams(window.location.search);
        const openId = params.get('openDealId');
        if (openId) {
          openDetail(Number(openId));
        }
      } catch (e) {
        console.error('[init]', e);
        showError('Yuklanishda xato: ' + e.message);
      }
    }
    
    function initWebSocket() {
      const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
      const ws = new WebSocket(protocol + '//' + window.location.host);
      ws.onmessage = (event) => {
        try {
          const data = JSON.parse(event.data);
          if (data && (data.type === 'deal_updated' || data.type === 'deal_deleted')) {
            // Re-fetch only deals, no need to reload pipelines/managers
            loadDeals();
          }
        } catch(e) {}
      };
      ws.onerror = (e) => console.error('WebSocket xatosi', e);
    }

    async function loadAll() {
      showLoading();
      try {
        await Promise.all([loadPipelines(), loadManagers(), loadClients()]);
        await loadDeals();
      } catch (e) {
        console.error('[loadAll]', e);
        showError(e.message);
      }
    }

    // ── API helpers ────────────────────────────────────────────────
    async function apiFetch(url, opts) {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 8000);
      const fetchOpts = Object.assign({ signal: controller.signal }, opts);
      let r;
      try {
        r = await fetch(url, fetchOpts);
        clearTimeout(timeoutId);
      } catch (err) {
        clearTimeout(timeoutId);
        throw new Error("Tarmoq xatosi yoki server ishlamayapti (Timeout).");
      }
      let data;
      try { data = await r.json(); } catch { data = {}; }
      if (!r.ok) {
        if (typeof _toast === 'function') _toast(data.message || 'Server xatosi: ' + r.status, 'error');
        throw new Error(data.message || 'Server xatosi: ' + r.status);
      }
      return data;
    }

    // ── Pipelines ──────────────────────────────────────────────────
    async function loadPipelines() {
      const data = await apiFetch('/api/pipelines');
      let allPipelines = Array.isArray(data) ? data : [];
      
      const isNasiyaPage = window.location.pathname.includes('/nasiya');
      if (isNasiyaPage) {
        _pipelines = allPipelines.filter(p => p.name.toLowerCase().includes('nasiya'));
      } else {
        _pipelines = allPipelines.filter(p => !p.name.toLowerCase().includes('nasiya'));
      }

      if (_pipelines.length && !_activePid) {
        _activePid = (_pipelines.find(p => p.isDefault) || _pipelines[0]).id;
      } else if (_pipelines.length && !_pipelines.find(p => p.id === _activePid)) {
        _activePid = _pipelines[0].id;
      }
      updateActiveStages();
      renderPipelineUI();
    }

    function updateActiveStages() {
      const p = _pipelines.find(x => x.id === _activePid);
      const real = p ? (p.stages || []) : [];
      if (real.length) {
        _stages = real;
        _usingMockStages = false;
      } else {
        // No real stages to show (no pipeline at all, or pipeline has 0
        // stages) — fall back to a local mock grid so the Kanban view never
        // shows an empty/broken board.
        _stages = DEFAULT_MOCK_STAGES;
        _usingMockStages = true;
      }
    }

    function setActivePipeline(id) {
      _activePid = id;
      updateActiveStages();
      renderPipelineUI();
      closePipelineDropdown();
      loadDeals();
    }

    function renderPipelineUI() {
      // Button text
      const p = _pipelines.find(x => x.id === _activePid);
      document.getElementById('pipelineNameText').textContent = p ? p.name : (_pipelines.length ? _pipelines[0].name : 'Voronka yo\'q');

      // Dropdown list
      const list = document.getElementById('pdropList');
      if (!_pipelines.length) {
        list.innerHTML = '<div style="padding:10px;font-size:13px;color:var(--text-tertiary)">Voronka yo\'q</div > ';
      } else {
        list.innerHTML = _pipelines.map(p => `
      <div class="pdrop-item${p.id===_activePid?' active':''}" onclick="setActivePipeline(${p.id})">
        <div class="pdrop-dot" style="background:${p.color||'#007AFF'}"></div>
        ${_esc(p.name)}
        ${p.isDefault ? '<span style="font-size:10px;color:var(--text-tertiary);margin-left:auto">default</span>' : ''}
      </div>
    `).join('');
  }

  // Stage filter / deal-form selects must always be kept in sync with
  // _usingMockStages, regardless of whether _pipelines is empty — this
  // branch must NOT early-return before reaching the code below, or the
  // deal-form stage select stays enabled with stale options while the
  // board is showing the local mock fallback grid.
  // Stage filter / deal-form selects must only ever offer REAL, persistable
  // stage ids. When the board is showing the local mock fallback grid,
  // these stay empty — selecting a mock id here would let a deal get
  // created/filtered against a stage that doesn't exist in the database.
  const selectableStages = _usingMockStages ? [] : _stages;

  // Stage filter dropdown
  const sel = document.getElementById('filterStage');
  const cur = sel.value;
  sel.innerHTML = '<option value="">Barcha bosqich</option>' +
    selectableStages.map(s => `<option value="${s.id}">${_esc(s.name)}</option>`).join('');
  if (cur) sel.value = cur;

  // Deal form stage select
  const fsel = document.getElementById('f-stageId');
  const fcur = fsel.value;
  fsel.disabled = _usingMockStages;
  fsel.innerHTML = (_usingMockStages
    ? '<option value="">— Avval voronka bosqichlarini sozlang —</option>'
    : '<option value="">— Bosqich —</option>' + selectableStages.map(s => `<option value="${s.id}">${_esc(s.name)}</option>`).join('')
  );
  if (fcur) fsel.value = fcur;
}

function togglePipelineDropdown() {
  document.getElementById('pipelineDropdown').classList.toggle('open');
}

function closePipelineDropdown() {
  document.getElementById('pipelineDropdown').classList.remove('open');
}

// Close dropdown when clicking outside
document.addEventListener('click', e => {
  if (!e.target.closest('#pipelineNameBtn') && !e.target.closest('#pipelineDropdown')) {
    closePipelineDropdown();
  }
});

// ── Managers ───────────────────────────────────────────────────
async function loadManagers() {
  try {
    const data = await apiFetch('/api/settings/users');
    _managers = Array.isArray(data) ? data : [];
    const sel = document.getElementById('filterManager');
    sel.innerHTML = '<option value="">Barcha manager</option>' +
      _managers.map(u => `<option value="${u.id}">${_esc(u.fullName||u.email)}</option>`).join('');
  } catch(e) { /* managers not critical */ }
}

// ── Clients ────────────────────────────────────────────────────
async function loadClients() {
  try {
    const data = await apiFetch('/api/clients');
    _clients = Array.isArray(data) ? data : [];
    const sel = document.getElementById('f-clientId');
    sel.innerHTML = '<option value="">— Mijoz tanlang —</option>' +
      _clients.map(c => `<option value="${c.id}">${_esc(c.name)}${c.company?' — '+_esc(c.company):''}</option>`).join('');
  } catch(e) { /* clients not critical */ }
}

// ── Deals ──────────────────────────────────────────────────────
async function loadDeals() {
  const q    = (document.getElementById('filterSearch').value||'').trim();
  const sid  = document.getElementById('filterStage').value;
  const mid  = document.getElementById('filterManager').value;
  const params = new URLSearchParams();
  if (q)   params.set('q', q);
  if (sid)  params.set('stageId', sid);
  if (mid)  params.set('managerId', mid);
  if (_activePid) params.set('pipelineId', _activePid);

  try {
    _deals = await apiFetch('/api/deals?' + params);
    if (!Array.isArray(_deals)) _deals = [];
  } catch(e) {
    _toast('Sdelkalar yuklanmadi: ' + e.message, 'error');
    _deals = [];
  }

  if (_view === 'kanban') renderKanban();
  else renderTable();
}

// ── Loading / error states ─────────────────────────────────────
function showLoading() {
  document.getElementById('kanbanBoard').innerHTML =
    '<div class="kb-state"><div class="spinner" style="width:36px;height:36px;border-width:3px"></div><p>Yuklanmoqda…</p></div>';
}

function showError(msg) {
  document.getElementById('kanbanBoard').innerHTML = `
    <div class="kb-state">
      <i class="fas fa-exclamation-triangle" style="color:var(--danger)"></i>
      <h3>Xatolik</h3>
      <p>${_esc(msg)}</p>
      <button class="btn btn-primary btn-sm" onclick="loadAll()"><i class="fas fa-redo"></i> Qayta urinish</button>
    </div>
  `;
}

// ── Kanban ─────────────────────────────────────────────────────
function renderKanban() {
  const board = document.getElementById('kanbanBoard');
  const banner = document.getElementById('kbMockBanner');
  if (banner) banner.style.display = _usingMockStages ? 'flex' : 'none';

  // Defensive fallback only — updateActiveStages() always guarantees
  // _stages is non-empty (real stages, or DEFAULT_MOCK_STAGES). This
  // branch should be unreachable, but if it's ever hit, never leave the
  // board permanently blank/frozen.
  if (!_stages.length) {
    board.innerHTML = `
      <div class="kb-state">
        <i class="fas fa-layer-group"></i>
