        <div class="kb-qadd-actions">
          <button class="btn btn-primary btn-sm" id="qaSaveBtn" onclick="submitQuickAdd()"><i class="fas fa-save"></i> Qo'shish</button>
          <button class="btn btn-ghost btn-sm" onclick="toggleQuickAdd()">Bekor</button>
