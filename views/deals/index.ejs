  }).join('') + (unassigned.length ? `
    <div class="kb-col" style="--_sc:var(--text-tertiary)">
      <div class="kb-col-hdr">
        <div class="kb-col-title">
          <div class="kb-col-dot" style="background:var(--text-tertiary)"></div>
          Bosqichsiz
        </div>
        <div class="kb-col-meta"><span>${unassigned.length}</span> sdelka</div>
      </div>
      <div class="kb-cards" id="col-null"
        ondragover="onDragOver(event)" ondragleave="onDragLeave(event)"
        ondrop="onDrop(event,null)">
        ${unassigned.map(d => dcardHtml(d)).join('')}
      </div>
    </div>
  ` : '') + (_editMode && !_usingMockStages && window.USER_ROLE === 'admin' ? `
    <button class="kb-addcol" onclick="addStageQuick()">
      <i class="fas fa-plus" style="font-size:18px"></i>
      <span>Yangi bosqich</span>
