<%- include('../layouts/header', { title: (typeof activePage !== 'undefined' && activePage === 'nasiya' ? 'Nasiya' : 'Sdelkalar') + ' — DESCO CRM', activePage: (typeof activePage !== 'undefined' ? activePage : 'deals'), user: user}) %>
 <style>
  /* ═══════════════════════════════════════════
  DEALS PAGE — amoCRM style
  ═══════════════════════════════════════════ */
  .deals-page { display:flex; flex-direction:column; height:calc(100vh - 110px); overflow:hidden; }

  /* ── Top bar ── */
  .deals-topbar {
  display:flex; align-items:center; gap:10px; padding:0 0 12px 0;
  flex-shrink:0; flex-wrap:wrap;
  }
  .pipeline-name-btn {
  display:flex; align-items:center; gap:6px;
  font-size:18px; font-weight:700; color:var(--text-primary);
  background:none; border:none; cursor:pointer; padding:4px 6px;
  border-radius:6px; transition:background 0.15s;
  }
  .pipeline-name-btn:hover { background:var(--bg-secondary); }
  .pipeline-name-btn i { font-size:12px; color:var(--text-tertiary); }

  .deals-topbar-right { display:flex; align-items:center; gap:8px; margin-left:auto; }
  .view-toggle { display:flex; background:var(--glass-bg); border:1px solid var(--glass-border); border-radius:8px;
  overflow:hidden; }
  .vtbtn {
  padding:6px 14px; font-size:12.5px; font-weight:500; border:none;
  background:none; color:var(--text-secondary); cursor:pointer; transition:all 0.14s;
  display:flex; align-items:center; gap:5px;
  }
  .vtbtn.active { background:var(--accent); color:#fff; }
  .vtbtn:hover:not(.active) { background:var(--bg-secondary); color:var(--text-primary); }

  /* ── Pipeline dropdown ── */
  .pipeline-dropdown {
  position:absolute; top:calc(100% + 6px); left:0; z-index:300;
  background:var(--bg-primary); border:1px solid var(--glass-border);
  border-radius:10px; box-shadow:0 8px 32px rgba(0,0,0,0.18);
  min-width:220px; padding:6px; display:none;
  }
  .pipeline-dropdown.open { display:block; }
  .pdrop-item {
  display:flex; align-items:center; gap:8px; padding:8px 10px;
  border-radius:7px; cursor:pointer; font-size:13px;
  color:var(--text-primary); transition:background 0.12s;
  }
  .pdrop-item:hover { background:var(--bg-secondary); }
  .pdrop-item.active { background:var(--accent-soft); color:var(--accent); font-weight:600; }
  .pdrop-dot { width:9px; height:9px; border-radius:50%; flex-shrink:0; }
  .pdrop-divider { height:1px; background:var(--glass-border); margin:4px 0; }
  .pdrop-action {
  display:flex; align-items:center; gap:7px; padding:7px 10px;
  border-radius:7px; cursor:pointer; font-size:12.5px;
  color:var(--text-secondary); transition:background 0.12s;
  }
  .pdrop-action:hover { background:var(--bg-secondary); color:var(--accent); }

  /* ── Filter bar ── */
  .deals-filter {
  display: flex; align-items: center; gap: 10px; margin-bottom: 16px;
  }
  .filter-search-wrap {
  position: relative; display: flex; align-items: center;
  }
  .filter-search-wrap i {
  position: absolute; left: 14px; color: var(--text-tertiary); font-size: 13px;
  }
  .filter-search-wrap input {
  padding-left: 36px;
  border-radius: 20px;
  background-color: var(--bg-primary);
  border: 1px solid var(--glass-border);
  box-shadow: 0 2px 6px rgba(0,0,0,0.02);
  transition: all 0.2s ease;
  font-size: 13px; height: 36px;
  }
  .filter-search-wrap input:hover { border-color: var(--border-med); box-shadow: 0 4px 10px rgba(0,0,0,0.04); }
  .filter-search-wrap input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); outline:
  none; }

  .filter-select {
  appearance: none;
  background-image:
  url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23999999%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E');
  background-repeat: no-repeat;
  background-position: right 14px center;
  background-size: 10px auto;
  padding-right: 32px; padding-left: 14px;
  border-radius: 20px;
  font-size: 13px; font-weight: 500; color: var(--text-secondary);
  background-color: var(--bg-primary);
  border: 1px solid var(--glass-border);
  cursor: pointer; height: 36px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.02);
  transition: all 0.2s ease;
  }
  .filter-select:hover { border-color: var(--border-med); box-shadow: 0 4px 10px rgba(0,0,0,0.04); color:
  var(--text-primary); }
  .filter-select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); outline: none; }

  .filter-clear-btn {
  width: 36px; height: 36px; border-radius: 50%;
  background: var(--bg-primary); border: 1px solid var(--glass-border);
  color: var(--text-tertiary); display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all 0.2s ease; box-shadow: 0 2px 6px rgba(0,0,0,0.02);
  }
  .filter-clear-btn:hover { background: var(--bg-secondary); color: var(--danger); border-color: var(--border-med);
  transform: scale(1.05); }

  /* ── Kanban board ── */
  .kanban-wrap { flex:1; overflow:hidden; display:flex; flex-direction:column; }
  .kb-board {
  display:flex; gap:10px; overflow-x:auto; overflow-y:hidden;
  flex:1; align-items:flex-start; padding-bottom:8px; width: 100%;
  }
  .kb-board::-webkit-scrollbar { height:5px; }
  .kb-board::-webkit-scrollbar-thumb { background:var(--border-med); border-radius:8px; }

  .kb-col {
  flex-shrink:0; width:260px; display:flex; flex-direction:column;
  max-height:100%; border-radius:10px;
  background:var(--glass-bg); border:1px solid var(--glass-border); overflow:hidden;
  }
  .kb-col-hdr {
  padding:10px 12px 8px; flex-shrink:0;
  border-top:3px solid var(--_sc, var(--accent));
  border-bottom:1px solid var(--glass-border);
  cursor:default;
  }
  .kb-col-title { display:flex; align-items:center; gap:7px; font-size:13px; font-weight:600; margin-bottom:3px; }
  .kb-col-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .kb-col-meta { font-size:11px; color:var(--text-tertiary); }
  .kb-col-meta span { color:var(--text-secondary); font-weight:600; }

  .kb-cards { flex:1; overflow-y:auto; padding:6px; min-height:120px; transition:background 0.12s; }
  .kb-cards::-webkit-scrollbar { width:3px; }
  .kb-cards::-webkit-scrollbar-thumb { background:var(--border-med); border-radius:4px; }
  .kb-cards.drag-over { background:rgba(0,122,255,0.08); }

  .kb-empty { padding:20px; text-align:center; color:var(--text-tertiary); font-size:12px; font-style:italic; }

  .kb-addbtn-wrap { padding:5px 6px 7px; flex-shrink:0; border-top:1px solid var(--glass-border); }
  .kb-addbtn {
  width:100%; background:none; border:1px dashed var(--border-med); border-radius:7px;
  padding:6px; font-size:12px; color:var(--text-tertiary); cursor:pointer;
  transition:all 0.14s; display:flex; align-items:center; justify-content:center; gap:5px;
  }
  .kb-addbtn:hover { border-color:var(--accent); color:var(--accent); background:var(--accent-soft); }

  /* ── Deal card ── */
  .dcard {
  background:var(--bg-secondary); border:1px solid var(--glass-border);
  border-radius:12px; padding:16px; margin-bottom:12px;
  cursor:pointer; user-select:none;
  transition:all 0.2s cubic-bezier(0.16,1,0.3,1);
  position:relative;
  display: flex; flex-direction: column; gap: 8px;
  box-shadow: var(--glass-shadow);
  }
  .dcard:hover { box-shadow:var(--glass-shadow-hover); transform:translateY(-3px); border-color:var(--border-med); }
  .dcard.dragging { opacity:0.4; transform:rotate(2deg) scale(1.04); box-shadow:0 20px 40px rgba(0,0,0,0.1); }
  .dcard-badge { display:inline-block; padding:4px 8px; border-radius:6px; font-size:10px; font-weight:700;
  text-transform:uppercase; letter-spacing:0.5px; }
  .dcard-header { display:flex; justify-content:space-between; align-items: center; margin-bottom:0px; }
  .dcard-company { font-size:12px; color:var(--text-secondary); margin-bottom:0; display:flex; align-items:center; gap:
  4px; }
  .dcard-name { font-size:15px; font-weight:600; color:var(--text-primary); margin-bottom:2px; line-height:1.4;
  padding-right:16px; }
  .dcard-footer { display:flex; align-items:center; justify-content:space-between; gap:6px; margin-top:4px; }
  .dcard-amount { font-size:14px; font-weight:700; color:var(--text-primary); }
  .dcard-right { display:flex; align-items:center; gap:6px; }
  .dcard-date { font-size:11px; color:var(--text-tertiary); font-weight:500; }
  .dcard-date.overdue { color:var(--danger); }
  .dcard-av { width:24px; height:24px; border-radius:50%; background:var(--bg-tertiary); color:var(--text-secondary);
  border: 1px solid var(--border); font-size:10px; font-weight:700; display:flex; align-items:center;
  justify-content:center; flex-shrink:0; }
  .dcard-progress { height:4px; background:var(--bg-tertiary); border-radius:4px; margin-top:6px; overflow:hidden; }
  .dcard-progress-fill { height:100%; background:var(--accent); border-radius:4px; transition:width 0.3s; }
  .dcard-contact { font-size: 12px; color: var(--text-secondary); display: flex; align-items: center; gap: 6px;
  background: var(--bg-primary); padding: 4px 8px; border-radius: 6px; width: fit-content; }
  .dcard-contact i { color: var(--text-tertiary); font-size: 11px; }
  .dcard-notes { font-size: 12px; color: var(--text-tertiary); font-style: normal; white-space: nowrap; overflow:
  hidden; text-overflow: ellipsis; max-width: 100%; padding-top: 4px;}
  .dcard-edit-btn { position:absolute; right:12px; top:12px; color:var(--text-tertiary); background:var(--bg-primary);
  border:1px solid var(--border); border-radius:6px; padding:4px 6px; cursor:pointer; opacity:0; transition:all 0.2s; }
  .dcard:hover .dcard-edit-btn { opacity:1; }
  .dcard-edit-btn:hover { color:var(--accent); border-color:var(--accent); }
  /* ── Table view ── */
  .table-wrap { flex:1; overflow:auto; }
  .deals-tbl { width:100%; border-collapse:collapse; }
  .deals-tbl th {
  position:sticky; top:0; background:var(--bg-secondary);
  padding:9px 12px; text-align:left; font-size:11px; font-weight:700;
  text-transform:uppercase; letter-spacing:0.5px; color:var(--text-tertiary);
  border-bottom:1px solid var(--glass-border); white-space:nowrap; z-index:2;
  }
  .deals-tbl td { padding:10px 12px; border-bottom:1px solid var(--glass-border); font-size:13px; vertical-align:middle;
  }
  .deals-tbl tr:hover td { background:var(--glass-bg); }
  .deals-tbl tr { cursor:pointer; }

  /* ── Filter bar ── */
  .deals-filter { display:flex; align-items:center; gap:8px; margin-bottom:10px; flex-wrap:wrap; flex-shrink:0; }
  .deals-filter .form-control { height:33px; font-size:13px; }
  .filter-search-wrap { position:relative; }
  .filter-search-wrap .fas { position:absolute; left:9px; top:50%; transform:translateY(-50%);
  color:var(--text-tertiary); font-size:12px; }
  .filter-search-wrap input { padding-left:28px; }

  /* ── States ── */
  .kb-state { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px; padding:40px;
  flex:1; color:var(--text-tertiary); text-align:center; }
  .kb-state i { font-size:40px; }

  /* ── Mock-stage fallback banner ── */
  .kb-mock-banner {
  display:flex; align-items:center; gap:9px; flex-shrink:0;
  background:rgba(255,149,0,0.1); border:1px solid rgba(255,149,0,0.35);
  border-radius:8px; padding:8px 12px; margin-bottom:10px; font-size:12.5px;
  color:var(--text-primary);
  }
  .kb-mock-banner i { color:#FF9500; font-size:14px; flex-shrink:0; }
  .kb-mock-banner span { flex:1; }
  .kb-state h3 { margin:0; color:var(--text-secondary); }
  .kb-state p { margin:0; font-size:13px; }

  /* ── Pipeline Manager ── */
  .pmgr-pitem {
  display:flex; align-items:center; gap:8px; padding:8px 10px;
  border-radius:7px; cursor:pointer; transition:background 0.12s; margin-bottom:2px;
  }
  .pmgr-pitem:hover { background:var(--bg-secondary); }
  .pmgr-pitem.active { background:var(--accent-soft); }
  .pmgr-sitem {
  display:flex; align-items:center; gap:8px; padding:7px 10px;
  border-radius:7px; border:1px solid var(--glass-border);
  background:var(--glass-bg); margin-bottom:5px;
  }
  .pmgr-sitem .sitem-actions { margin-left:auto; display:flex; gap:4px; opacity:0; transition:opacity 0.1s; }
  .pmgr-sitem:hover .sitem-actions { opacity:1; }

  /* ── Status badge ── */
  .status-dot { display:inline-block; width:8px; height:8px; border-radius:50%; margin-right:5px; }
  .status-new { background:#007AFF; }
  .status-negotiation{ background:#FF9500; }
  .status-proposal { background:#5856D6; }
  .status-won { background:#34C759; }
  .status-lost { background:#FF3B30; }

  /* ── Quick Add (Быстрое добавление) ── */
  .kb-qadd-toggle {
  width:100%; background:var(--accent-soft); border:1px solid transparent; border-radius:7px;
  padding:7px; font-size:12px; font-weight:600; color:var(--accent); cursor:pointer;
  transition:all 0.14s; display:flex; align-items:center; justify-content:center; gap:5px; margin-bottom:6px;
  }
  .kb-qadd-toggle:hover { background:var(--accent); color:#fff; }
  .kb-qadd-panel {
  background:var(--bg-secondary); border:1px solid var(--glass-border); border-radius:8px;
  padding:9px; margin:0 6px 8px; display:none; flex-direction:column; gap:6px;
  }
  .kb-qadd-panel.open { display:flex; }
  .kb-qadd-panel input {
  width:100%; height:28px; font-size:12px; padding:0 8px; border-radius:6px;
  border:1px solid var(--glass-border); background:var(--bg-primary); color:var(--text-primary);
  }
  .kb-qadd-panel .kb-qadd-row { display:flex; gap:6px; }
  .kb-qadd-panel .kb-qadd-actions { display:flex; gap:6px; margin-top:2px; }
  .kb-qadd-panel .kb-qadd-actions button { flex:1; font-size:11px; padding:6px; }
  .kb-qadd-label { font-size:9.5px; font-weight:700; text-transform:uppercase; letter-spacing:0.4px;
  color:var(--text-tertiary); margin:2px 0 -2px; }

  /* ── Settings / Edit Mode ── */
  .kb-settings-btn { display:flex; align-items:center; gap:6px; }
  .kb-settings-btn.active { background:var(--accent); color:#fff; }
  .kb-editmode-banner {
  display:flex; align-items:center; gap:9px; flex-shrink:0;
  background:rgba(0,122,255,0.08); border:1px solid rgba(0,122,255,0.3);
  border-radius:8px; padding:8px 12px; margin-bottom:10px; font-size:12.5px;
  }
  .kb-editmode-banner i { color:var(--accent); }
  .kb-col.editing { border:1.5px dashed var(--accent); cursor:grab; }
  .kb-col.col-dragging { opacity:0.4; }
  .kb-col.col-drag-over { box-shadow:inset 0 0 0 2px var(--accent); }
  .kb-col-hdr-edit { display:flex; align-items:center; gap:6px; }
  .kb-col-hdr-edit i.fa-grip-vertical { color:var(--text-tertiary); cursor:grab; flex-shrink:0; }
  .kb-col-rename {
  flex:1; height:26px; font-size:12.5px; font-weight:600; padding:0 6px;
  border:1px solid var(--glass-border); border-radius:5px; background:var(--bg-primary); color:var(--text-primary);
  }
  .kb-col-del { color:var(--text-tertiary); cursor:pointer; flex-shrink:0; padding:2px 4px; }
  .kb-col-del:hover { color:var(--danger); }
  .kb-addcol {
  flex-shrink:0; width:180px; align-self:flex-start; border:1.5px dashed var(--border-med);
  border-radius:10px; background:none; color:var(--text-tertiary); cursor:pointer;
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px;
  padding:20px 10px; font-size:12.5px; transition:all 0.14s; min-height:70px;
  }
  .kb-addcol:hover { border-color:var(--accent); color:var(--accent); background:var(--accent-soft); }

  /* ── Drop placeholder ── */
  .kb-drop-placeholder {
  border:2px dashed var(--accent); border-radius:7px; background:rgba(0,122,255,0.07);
  height:54px; margin-bottom:5px; flex-shrink:0; pointer-events:none;
  }

  /* ── Won/Lost bottom drop zones ── */
  .kb-resultzones { display:flex; gap:10px; flex-shrink:0; margin-top:8px; }
  .kb-rzone {
  flex:1; border:2px dashed transparent; border-radius:10px; padding:10px 14px;
  display:flex; align-items:center; justify-content:center; gap:8px;
  font-size:13px; font-weight:600; transition:all 0.15s; min-height:44px;
  }
  .kb-rzone i { font-size:15px; }
  .kb-rzone-lost { background:rgba(255,59,48,0.08); border-color:rgba(255,59,48,0.35); color:#FF3B30; }
  .kb-rzone-won { background:rgba(52,199,89,0.08); border-color:rgba(52,199,89,0.35); color:#34C759; }
  .kb-rzone.rzone-over.kb-rzone-lost { background:rgba(255,59,48,0.22); border-color:#FF3B30; transform:scale(1.02); }
  .kb-rzone.rzone-over.kb-rzone-won { background:rgba(52,199,89,0.22); border-color:#34C759; transform:scale(1.02); }
  </style>

  <div class="deals-page">

    <!-- Top bar -->
    <div class="deals-topbar">
      <div style="position:relative;">
        <button class="pipeline-name-btn" id="pipelineNameBtn" onclick="togglePipelineDropdown()">
          <span id="pipelineNameText">Yuklanmoqda…</span>
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="pipeline-dropdown" id="pipelineDropdown">
          <div id="pdropList"></div>
          <div class="pdrop-divider"></div>
          <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %><div class="pdrop-action" onclick="closePipelineDropdown();openPipelineMgr()"><i class="fas fa-cog"></i> Voronkalarni boshqarish</div><% } %>
        </div>
      </div>

      <div class="deals-topbar-right">
        <div class="view-toggle">
          <button class="vtbtn active" id="btnKanban" onclick="setView('kanban')">
            <i class="fas fa-columns"></i> Kanban
          </button>
          <button class="vtbtn" id="btnTable" onclick="setView('table')">
            <i class="fas fa-list"></i> Jadval
          </button>
        </div>
        <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %><button class="btn btn-ghost btn-sm kb-settings-btn" id="btnEditMode" onclick="toggleEditMode()" title="Bosqichlarni tahrirlash"><i class="fas fa-cog"></i> Sozlash</button><% } %>
        <button class="btn btn-primary btn-sm" onclick="openDealModal()">
          <i class="fas fa-plus"></i> Yangi sdelka
        </button>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="deals-filter">
      <div class="filter-search-wrap">
        <i class="fas fa-search"></i>
        <input type="text" id="filterSearch" placeholder="Qidirish…" style="width:220px">
      </div>
      <select id="filterStage" class="filter-select" style="width:160px">
        <option value="">Barcha bosqich</option>
      </select>
      <select id="filterManager" class="filter-select" style="width:160px">
        <option value="">Barcha manager</option>
      </select>
      <button class="filter-clear-btn" onclick="clearFilters()" title="Filtrni tozalash">
        <i class="fas fa-times"></i>
      </button>
    </div>

    <!-- Kanban wrapper -->
    <div class="kanban-wrap" id="kanbanWrap">
      <div class="kb-mock-banner" id="kbMockBanner" style="display:none">
        <i class="fas fa-info-circle"></i>
        <span>Bu namuna bosqichlar — hali haqiqiy voronka sozlanmagan. Sdelkalarni bu bosqichlarga ko'chirib bo'lmaydi,
          avval voronkani sozlang.</span>
        <button class="btn btn-primary btn-sm" onclick="openPipelineMgr()"><i class="fas fa-cog"></i> Sozlash</button>
      </div>
      <div class="kb-editmode-banner hidden" id="kbEditBanner">
        <i class="fas fa-pen"></i>
        <span><strong>Tahrirlash rejimi:</strong> ustun nomini bosib o'zgartiring, sarlavhadagi <i
            class="fas fa-grip-vertical"></i> belgisidan tutib tartibni o'zgartiring yoki o'ngdagi "+" orqali yangi
          bosqich qo'shing.</span>
        <button class="btn btn-secondary btn-sm" onclick="toggleEditMode()">Tayyor</button>
      </div>
      <div class="kb-board" id="kanbanBoard">
        <div class="kb-state">
          <div class="spinner" style="width:36px;height:36px;border-width:3px"></div>
          <p>Yuklanmoqda…</p>
        </div>
      </div>
      <div class="kb-resultzones" id="kbResultZones">
        <div class="kb-rzone kb-rzone-lost" id="rzoneLost" ondragover="onZoneDragOver(event)"
          ondragleave="onZoneDragLeave(event)" ondrop="onZoneDrop(event,'lost')">
