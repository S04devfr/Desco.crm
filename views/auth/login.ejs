<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kirish — DESCO CRM</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/custom.css">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;background:var(--bg-primary);color:var(--text-primary);-webkit-font-smoothing:antialiased}
    
    .bg { position: fixed; inset: 0; z-index: 0; background: var(--bg-primary); }
    .mesh-gradient { position: absolute; inset: 0; z-index: 0; background: radial-gradient(circle at 50% -20%, var(--accent-soft), transparent 60%); }
    .grid { position: fixed; inset: 0; z-index: 0; background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px); background-size: 40px 40px; opacity: 0.5; }
    
    .card { position: relative; z-index: 1; width: 100%; max-width: 400px; margin: 24px; background: var(--bg-secondary); border-radius: 20px; border: 1px solid var(--glass-border); box-shadow: var(--glass-shadow-hover); padding: 48px 40px; animation: cardIn .6s cubic-bezier(.16,1,.3,1); }
    @keyframes cardIn { from { opacity: 0; transform: translateY(24px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
    
    .logo { text-align: center; margin-bottom: 40px; }
    .logo-text { font-size: 28px; font-weight: 800; color: var(--text-primary); letter-spacing: -1px; display: flex; align-items: center; justify-content: center; gap: 10px; }
    .logo-text span { color: var(--accent); }
    .logo-icon { width: 46px; height: 46px; background: var(--accent); border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 20px; box-shadow: 0 8px 20px rgba(37,99,235,0.3); margin-right: 4px; }
    .logo p { color: var(--text-secondary); font-size: 15px; margin-top: 14px; font-weight: 400; }
    
    .error-box { background: var(--danger-bg); color: var(--danger); padding: 14px 16px; border-radius: 12px; font-size: 14px; margin-bottom: 24px; display: none; border: 1px solid rgba(239,68,68,0.2); text-align: center; font-weight: 500; }
    
    .lbl { display: block; font-size: 13px; font-weight: 500; color: var(--text-secondary); margin-bottom: 8px; }
    .fg { margin-bottom: 22px; }
    .inp { width: 100%; padding: 14px 16px; background: var(--bg-primary); border: 1px solid var(--border-med); border-radius: 12px; font-size: 15px; color: var(--text-primary); outline: none; transition: all 0.2s ease; font-family: inherit; }
    .inp::placeholder { color: var(--text-tertiary); }
    .inp:focus { background: var(--bg-secondary); border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-soft); }
    
    .btn { width: 100%; padding: 14px 20px; background: var(--accent); border: none; border-radius: 12px; color: #fff; font-size: 15px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.2s ease; margin-top: 16px; font-family: inherit; box-shadow: 0 4px 12px rgba(37,99,235,0.3); }
    .btn:hover { transform: translateY(-2px); background: var(--accent-hover); box-shadow: 0 8px 20px rgba(37,99,235,0.4); }
    .btn:active { transform: scale(0.98); }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    
    .footer { text-align: center; margin-top: 32px; font-size: 14px; color: var(--text-secondary); }
    .footer a { color: var(--accent); text-decoration: none; font-weight: 500; transition: color 0.2s; }
    .footer a:hover { color: var(--accent-hover); }
    
    .spin { width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.6s linear infinite; display: inline-block; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
  <script>
    (function() {
      const t = localStorage.getItem('crm-theme') || 'light';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
<div class="bg">
  <div class="mesh-gradient"></div>
</div>
<div class="grid"></div>

<div class="card">
  <div class="logo">
    <div class="logo-text">
      <div class="logo-icon"><i class="fas fa-layer-group"></i></div>
      Desco<span>.crm</span>
    </div>
    <p>Tizimga xush kelibsiz</p>
  </div>

  <div class="error-box" id="errorBox"></div>

  <form id="loginForm">
    <div class="fg">
      <label class="lbl">Email manzil</label>
      <input type="email" id="email" class="inp" placeholder="email@example.com" required autofocus autocomplete="username">
    </div>
    <div class="fg">
      <label class="lbl">Parol</label>
      <input type="password" id="password" class="inp" placeholder="••••••••" required autocomplete="current-password">
    </div>
    <button type="submit" class="btn" id="loginBtn">
      <i class="fas fa-right-to-bracket"></i> Kirish
    </button>
  </form>

  <div class="footer">
    Akkaunt yo'qmi? <a href="/register">Ro'yxatdan o'tish</a>
  </div>
</div>

<script>
document.getElementById('loginForm').addEventListener('submit', async e => {
  e.preventDefault();
  const err = document.getElementById('errorBox');
  const btn = document.getElementById('loginBtn');
  err.style.display = 'none';
  btn.disabled = true;
  btn.innerHTML = '<div class="spin"></div> Kirilmoqda...';
  try {
    const r = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: document.getElementById('email').value, password: document.getElementById('password').value })
    });
    const data = await r.json();
    if (!r.ok) {
      err.textContent = data.message || 'Xatolik yuz berdi';
      err.style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-right-to-bracket"></i> Kirish';
      return;
    }
    window.location.href = '/';
  } catch {
    err.textContent = "Server bilan bog'lanishda xatolik";
    err.style.display = 'block';
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-right-to-bracket"></i> Kirish';
  }
});
</script>
</body>
</html>
