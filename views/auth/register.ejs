<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ro'yxatdan o'tish — DESCO CRM</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',-apple-system,sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;background:#040010;-webkit-font-smoothing:antialiased}
    .bg{position:fixed;inset:0;z-index:0;background:radial-gradient(ellipse 100% 80% at 20% 10%,#0d2850 0%,transparent 55%),radial-gradient(ellipse 80% 70% at 80% 90%,#200840 0%,transparent 55%),#040010}
    .orb{position:absolute;border-radius:50%;filter:blur(90px);opacity:.5;animation:float 9s ease-in-out infinite}
    .orb:nth-child(1){width:500px;height:500px;background:radial-gradient(circle,#0055cc 0%,transparent 70%);top:-100px;left:-100px}
    .orb:nth-child(2){width:450px;height:450px;background:radial-gradient(circle,#4a00a0 0%,transparent 70%);bottom:-80px;right:-80px;animation-delay:-4s}
    @keyframes float{0%,100%{transform:translate(0,0)}50%{transform:translate(20px,-20px)}}
    .card{position:relative;z-index:1;width:100%;max-width:420px;margin:16px;background:rgba(255,255,255,.07);backdrop-filter:blur(48px) saturate(200%);-webkit-backdrop-filter:blur(48px) saturate(200%);border-radius:28px;border:1px solid rgba(255,255,255,.13);box-shadow:0 40px 100px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.18);padding:40px 38px;animation:cardIn .5s cubic-bezier(.34,1.2,.64,1)}
    @keyframes cardIn{from{opacity:0;transform:translateY(24px) scale(.96)}to{opacity:1;transform:none}}
    .logo{text-align:center;margin-bottom:28px}
    .logo img{max-width:160px;max-height:60px;object-fit:contain;margin-bottom:8px}
    .logo h1{font-size:22px;font-weight:800;color:#fff;margin-bottom:4px}
    .logo p{color:rgba(255,255,255,.45);font-size:13px}
    .logo-icon{width:52px;height:52px;background:linear-gradient(135deg,rgba(0,122,255,.6),rgba(88,86,214,.8));border-radius:15px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;color:#fff;font-size:22px}
    .err{background:rgba(255,59,48,.18);color:#ffb3ae;padding:10px 14px;border-radius:12px;font-size:13px;margin-bottom:16px;display:none;border:1px solid rgba(255,59,48,.3)}
    .lbl{display:block;font-size:11px;font-weight:600;color:rgba(255,255,255,.5);margin-bottom:6px;text-transform:uppercase;letter-spacing:.6px}
    .fg{margin-bottom:15px}
    .inp{width:100%;padding:11px 14px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);border-radius:12px;font-size:14px;color:#fff;outline:none;transition:all .2s;font-family:inherit}
    .inp::placeholder{color:rgba(255,255,255,.28)}
    .inp:focus{background:rgba(255,255,255,.13);border-color:rgba(0,122,255,.7);box-shadow:0 0 0 3px rgba(0,122,255,.2)}
    .btn{width:100%;padding:13px 20px;background:linear-gradient(135deg,#0066dd,#007AFF);border:1px solid rgba(255,255,255,.2);border-radius:14px;color:#fff;font-size:14px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .2s;margin-top:6px;font-family:inherit;box-shadow:0 4px 20px rgba(0,122,255,.4)}
    .btn:hover{transform:translateY(-1px);box-shadow:0 8px 28px rgba(0,122,255,.5)}
    .btn:disabled{opacity:.6;cursor:not-allowed;transform:none}
    .footer{text-align:center;margin-top:20px;font-size:13px;color:rgba(255,255,255,.38)}
    .footer a{color:rgba(100,180,255,.9);text-decoration:none;font-weight:600}
    .spin{width:18px;height:18px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;display:inline-block}
    @keyframes spin{to{transform:rotate(360deg)}}
  </style>
</head>
<body>
<div class="bg"><div class="orb"></div><div class="orb"></div></div>

<div class="card">
  <div class="logo">
    <img src="/images/logo.jpg" alt="DESCO" onerror="this.style.display='none';document.getElementById('fb').style.display='block'">
    <div id="fb" style="display:none">
      <div class="logo-icon"><i class="fas fa-chart-bar"></i></div>
      <h1>DESCO CRM</h1>
    </div>
    <p>Yangi akkaunt yaratish</p>
  </div>

  <div class="err" id="errBox"></div>

  <form id="regForm">
    <div class="fg">
      <label class="lbl">Ism-familiya</label>
      <input type="text" id="fullName" class="inp" placeholder="To'liq ism" autofocus>
    </div>
    <div class="fg">
      <label class="lbl">Email *</label>
      <input type="email" id="email" class="inp" placeholder="email@example.com" required>
    </div>
    <div class="fg">
      <label class="lbl">Parol *</label>
      <input type="password" id="password" class="inp" placeholder="Kamida 6 belgi" required>
    </div>
    <button type="submit" class="btn" id="regBtn">
      <i class="fas fa-user-plus"></i> Ro'yxatdan o'tish
    </button>
  </form>

  <div class="footer">
    Akkount bormi? <a href="/login">Kirish</a>
  </div>
</div>

<script>
document.getElementById('regForm').addEventListener('submit', async e => {
  e.preventDefault();
  const err = document.getElementById('errBox');
  const btn = document.getElementById('regBtn');
  err.style.display = 'none';
  btn.disabled = true;
  btn.innerHTML = '<div class="spin"></div> Yuborilmoqda...';
  try {
    const r = await fetch('/api/auth/register', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        fullName: document.getElementById('fullName').value,
        email: document.getElementById('email').value,
        password: document.getElementById('password').value
      })
    });
    const data = await r.json();
    if (!r.ok) {
      err.textContent = data.message || 'Xatolik';
      err.style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-user-plus"></i> Ro\'yxatdan o\'tish';
      return;
    }
    window.location.href = '/';
  } catch {
    err.textContent = "Server bilan bog'lanishda xatolik";
    err.style.display = 'block';
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-user-plus"></i> Ro\'yxatdan o\'tish';
  }
});
</script>
</body>
</html>
