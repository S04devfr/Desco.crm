<%- include('../layouts/base', {
    title: 'Xarajatlar - DESCO CRM',
    body: `
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">🚗 Xarajatlar</h1>
            <p class="text-gray-600 mt-1">Logistika va boshqa xarajatlar</p>
        </div>
    </div>

    <!-- ADD EXPENSE FORM -->
    <div class="card-shadow mb-8">
        <h3 class="text-lg font-bold text-gray-800 mb-4">➕ Yangi xarajat qo'shish</h3>
        <form id="expenseForm" class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <input type="text" name="description" placeholder="Tavsif" required class="px-4 py-2 border border-gray-300 rounded-lg">
            <input type="number" name="amount" placeholder="Summa" required class="px-4 py-2 border border-gray-300 rounded-lg">
            <select name="category" class="px-4 py-2 border border-gray-300 rounded-lg">
                <option value="logistics">Logistika</option>
                <option value="office">Ofis</option>
                <option value="marketing">Marketing</option>
                <option value="other">Boshqa</option>
            </select>
            <input type="date" name="date" class="px-4 py-2 border border-gray-300 rounded-lg">
            <button type="submit" class="btn-primary md:col-span-4">Qo'shish</button>
        </form>
    </div>

    <!-- EXPENSES TABLE -->
    <div class="card-shadow">
        <table class="w-full text-left">
            <thead>
                <tr class="border-b border-gray-200">
                    <th class="py-2 px-3">ID</th>
                    <th class="py-2 px-3">Tavsif</th>
                    <th class="py-2 px-3">Kategoriya</th>
                    <th class="py-2 px-3">Summa</th>
                    <th class="py-2 px-3">Sana</th>
                    <th class="py-2 px-3">Qo'shgan</th>
                </tr>
            </thead>
            <tbody id="expensesTableBody">
                <tr><td colspan="6" class="py-4 text-center text-gray-500">Yuklanmoqda...</td></tr>
            </tbody>
        </table>
    </div>

    <script>
        async function loadExpenses() {
            try {
                const response = await fetch('/api/expenses');
                const expenses = await response.json();
                const tbody = document.getElementById('expensesTableBody');

                if (!Array.isArray(expenses) || expenses.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="py-4 text-center text-gray-500">Xarajatlar topilmadi</td></tr>';
                    return;
                }

                tbody.innerHTML = expenses.map(expense => \`
                    <tr class="border-b border-gray-100 hover:bg-gray-50">
                        <td class="py-2 px-3">#\${expense.id}</td>
                        <td class="py-2 px-3">\${expense.description}</td>
                        <td class="py-2 px-3">\${expense.category}</td>
                        <td class="py-2 px-3">\${formatCurrency(expense.amount)}</td>
                        <td class="py-2 px-3">\${new Date(expense.date).toLocaleDateString('uz-UZ')}</td>
                        <td class="py-2 px-3">\${expense.createdBy ? expense.createdBy.fullName : '-'}</td>
                    </tr>
                \`).join('');
            } catch (error) {
                console.error('Expenses loading error:', error);
            }
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('uz-UZ', { style: 'currency', currency: 'UZS', minimumFractionDigits: 0 }).format(value || 0);
        }

        document.getElementById('expenseForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const data = {
                description: form.description.value,
                amount: form.amount.value,
                category: form.category.value,
                date: form.date.value || undefined
            };

            try {
                const response = await fetch('/api/expenses', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (!response.ok) {
                    const err = await response.json();
                    showToast(err.message || 'Xatolik yuz berdi', 'error');
                    return;
                }

                form.reset();
                showToast('✅ Xarajat qo\\'shildi!', 'success');
                loadExpenses();
            } catch (error) {
                console.error('Create expense error:', error);
            }
        });

        loadExpenses();
    </script>
    `
}) %>
