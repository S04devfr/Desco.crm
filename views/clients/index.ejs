<%- include('../layouts/base', {
    title: 'Kontaktlar - DESCO CRM',
    body: `
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">👥 Kontaktlar</h1>
            <p class="text-gray-600 mt-1">Mijozlar ro'yxati</p>
        </div>
    </div>

    <!-- ADD CLIENT FORM -->
    <div class="card-shadow mb-8">
        <h3 class="text-lg font-bold text-gray-800 mb-4">➕ Yangi mijoz qo'shish</h3>
        <form id="clientForm" class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <input type="text" name="name" placeholder="Ism" required class="px-4 py-2 border border-gray-300 rounded-lg">
            <input type="text" name="phone" placeholder="Telefon" class="px-4 py-2 border border-gray-300 rounded-lg">
            <input type="email" name="email" placeholder="Email" class="px-4 py-2 border border-gray-300 rounded-lg">
            <input type="text" name="company" placeholder="Kompaniya" class="px-4 py-2 border border-gray-300 rounded-lg">
            <button type="submit" class="btn-primary md:col-span-4">Qo'shish</button>
        </form>
    </div>

    <!-- CLIENTS TABLE -->
    <div class="card-shadow">
        <table class="w-full text-left">
            <thead>
                <tr class="border-b border-gray-200">
                    <th class="py-2 px-3">ID</th>
                    <th class="py-2 px-3">Ism</th>
                    <th class="py-2 px-3">Telefon</th>
                    <th class="py-2 px-3">Email</th>
                    <th class="py-2 px-3">Kompaniya</th>
                    <th class="py-2 px-3">Egasi</th>
                    <th class="py-2 px-3">Sdelkalar</th>
                </tr>
            </thead>
            <tbody id="clientsTableBody">
                <tr><td colspan="7" class="py-4 text-center text-gray-500">Yuklanmoqda...</td></tr>
            </tbody>
        </table>
    </div>

    <script>
        async function loadClients() {
            try {
                const response = await fetch('/api/clients');
                const clients = await response.json();
                const tbody = document.getElementById('clientsTableBody');

                if (!Array.isArray(clients) || clients.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="7" class="py-4 text-center text-gray-500">Mijozlar topilmadi</td></tr>';
                    return;
                }

                tbody.innerHTML = clients.map(client => \`
                    <tr class="border-b border-gray-100 hover:bg-gray-50">
                        <td class="py-2 px-3">#\${client.id}</td>
                        <td class="py-2 px-3">\${client.name}</td>
                        <td class="py-2 px-3">\${client.phone || '-'}</td>
                        <td class="py-2 px-3">\${client.email || '-'}</td>
                        <td class="py-2 px-3">\${client.company || '-'}</td>
                        <td class="py-2 px-3">\${client.owner ? client.owner.fullName : '-'}</td>
                        <td class="py-2 px-3">\${client.deals ? client.deals.length : 0}</td>
                    </tr>
                \`).join('');
            } catch (error) {
                console.error('Clients loading error:', error);
            }
        }

        document.getElementById('clientForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const data = {
                name: form.name.value,
                phone: form.phone.value,
                email: form.email.value,
                company: form.company.value
            };

            try {
                const response = await fetch('/api/clients', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (!response.ok) {
                    const err = await response.json();
                    showToast(err.message || 'Xatolik yuz berdi', 'error');
                    return;
                }

                form.reset();
                showToast('✅ Mijoz qo\\'shildi!', 'success');
                loadClients();
            } catch (error) {
                console.error('Create client error:', error);
            }
        });

        loadClients();
    </script>
    `
}) %>
