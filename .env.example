# Database (Supabase PostgreSQL)
# Supabase Dashboard → Settings → Database → Connection String (URI) dan oling
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct URL (Prisma Migrate uchun — pooler EMAS)
# Supabase Dashboard → Settings → Database → Connection String (Direct) dan oling
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Server
PORT=3000
NODE_ENV=production

# JWT (production uchun kuchli secret ishlating!)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# Session (production uchun kuchli secret ishlating!)
SESSION_SECRET=your_session_secret_change_in_production

# Admin credentials (birinchi marta server ishga tushganda yaratiladi)
ADMIN_EMAIL=admin@desco.com
ADMIN_PASSWORD=Admin@123

# Webhook Security Token
WEBHOOK_SECRET_TOKEN=desco-crm-secret-2026
